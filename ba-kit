# ============================================================
# Public products always included. Private products probed only with gh auth.
select_product() {
  local can_private=false
  github_auth_available && can_private=true

  local accessible_ids=() accessible_names=() accessible_repos=() accessible_indices=()

  local i=0
  while [ "$i" -lt "${#PRODUCT_IDS[@]}" ]; do
    local vis="${PRODUCT_VISIBILITIES[$i]}"
    local repo="${PRODUCT_REPOS[$i]}"

    if [ "$vis" = "public" ]; then
      accessible_indices+=("$i")
      accessible_names+=("${PRODUCT_NAMES[$i]}")
    elif $can_private; then
      if gh api "repos/${repo}" --jq '.private' &>/dev/null 2>&1; then
        accessible_indices+=("$i")
        accessible_names+=("${PRODUCT_NAMES[$i]}")
      fi
    fi
    i=$((i + 1))
  done

  if [ ${#accessible_indices[@]} -eq 0 ]; then
    echo ""
    echo "=============================================="
    echo "  CHƯA CÓ QUYỀN TRUY CẬP"
    echo "=============================================="
    echo ""
    echo "Bạn chưa có quyền truy cập bất kỳ sản phẩm BA-kit nào."
    echo ""
    echo "BA-kit Solo Basic là sản phẩm miễn phí — vui lòng báo lỗi này."
    echo ""
    echo "Các sản phẩm trả phí:"
    for j in "${!PRODUCT_NAMES[@]}"; do
      echo "    ${PRODUCT_NAMES[$j]}: ${PRODUCT_URLS[$j]}"
    done
    echo "=============================================="
    exit 1
  fi

  if [ ${#accessible_indices[@]} -eq 1 ]; then
    select_product_index "${accessible_indices[0]}"
    echo "  Phát hiện: ${SELECTED_PRODUCT}"
    if ! $can_private && [ "$SELECTED_VISIBILITY" = "public" ]; then
      echo "  (sản phẩm riêng tư cần 'gh auth login' để hiển thị)"
    fi
    return 0
  fi

  # Multiple candidates — numbered prompt
  echo ""
  echo "Bạn có quyền truy cập nhiều sản phẩm BA-kit:"
  echo ""
  local j=0
  while [ "$j" -lt "${#accessible_indices[@]}" ]; do
    echo "  [$((j+1))] ${accessible_names[$j]}"
    j=$((j + 1))
  done
  echo ""
  read -r -p "Chọn sản phẩm muốn cài (1-${#accessible_indices[@]}): " choice

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#accessible_indices[@]} ]; then
    echo "Lựa chọn không hợp lệ."
    exit 1
  fi

  local pick=$((choice - 1))
  select_product_index "${accessible_indices[$pick]}"
  echo "  Đã chọn: ${SELECTED_PRODUCT}"
}

# ============================================================
# B3: RELEASE CLIENT (public/private)
# ============================================================
get_release_json() {
  local target="${1:-latest}"
  local endpoint

  if [ "$target" = "latest" ]; then
    endpoint="repos/${SELECTED_REPO}/releases/latest"
  else
    # Encode tag for URL
    local encoded_tag
    encoded_tag=$(echo "$target" | sed 's/ /%20/g')
    endpoint="repos/${SELECTED_REPO}/releases/tags/${encoded_tag}"
  fi

  if [ "$SELECTED_VISIBILITY" = "public" ]; then
    local json
    json=$(curl -fsSL -H "Accept: application/vnd.github+json" \
      "https://api.github.com/${endpoint}" 2>/dev/null) || {
      echo "Lỗi: Không thể lấy release công khai của ${SELECTED_PRODUCT}. Kiểm tra mạng và thử lại."
      exit 1
    }
    echo "$json"
  else
    require_private_github_access "$SELECTED_PRODUCT"
    local json
    json=$(gh api "${endpoint}" 2>/dev/null) || {
      echo "Lỗi: Không thể lấy release của ${SELECTED_PRODUCT}."
      exit 1
    }
    echo "$json"
  fi
}

# ============================================================
# B3: CHỌN VERSION
# ============================================================
select_version() {
  local target="${1:-latest}"

  if [ "$target" = "latest" ]; then
    echo "Đang tìm phiên bản mới nhất..."
  fi

  local release_json
  release_json=$(get_release_json "$target") || exit 1
  SELECTED_VERSION=$(echo "$release_json" | jq -r '.tag_name')
  RELEASE_NOTES=$(echo "$release_json" | jq -r '.body // ""')

  echo "  Phiên bản: ${SELECTED_VERSION}"
  if [ -n "${RELEASE_NOTES:-}" ] && [ "${RELEASE_NOTES:-}" != "null" ]; then
    echo ""
    echo "Thay đổi trong phiên bản này:"
    echo "----------------------------------------"
    echo "$RELEASE_NOTES" | head -20
    echo "----------------------------------------"
    echo ""
  fi
}

# ============================================================
# B4: KIỂM TRA XUNG ĐỘT SẢN PHẨM
# ============================================================
# Per-runtime conflict/version check, used by multi-runtime install.
# Returns 0 = process this runtime, 1 = skip it (already up to date).
# With exactly 1 runtime selected, behavior is byte-identical to
# check_cross_product (same interactive reinstall prompt). With 2+
# runtimes selected, an already-up-to-date runtime is skipped silently
# instead of prompting once per runtime.
check_cross_product_for_runtime() {
  local key="$1"
  local product_file version_file label
  product_file=$(runtime_product_file "$key")
  version_file=$(runtime_version_file "$key")
  label=$(runtime_label_for_key "$key")

  if [ ! -f "$product_file" ]; then
    return 0
  fi

  local existing_product
  existing_product=$(cat "$product_file")

  if [ "$existing_product" != "$SELECTED_PRODUCT" ]; then
    echo ""
    echo "=============================================="
    echo "  PHÁT HIỆN XUNG ĐỘT SẢN PHẨM (${label})"
    echo "=============================================="
    echo ""
    echo "Local đang cài: ${existing_product}"
    echo "Bạn muốn cài:   ${SELECTED_PRODUCT}"
    echo ""
    echo "Không thể cài đè sản phẩm khác. Bạn cần gỡ ${existing_product} trước:"
    echo ""
    echo "  ba-kit uninstall --runtime ${key}"
    echo ""
    echo "Sau đó chạy lại:"
    echo "  ba-kit install --runtime ${key}"
    echo "=============================================="
    exit 1
  fi

  if [ -f "$version_file" ]; then
    local current
    current=$(cat "$version_file")
    if [ "${current#v}" = "${SELECTED_VERSION#v}" ]; then
      if [ ${#SELECTED_RUNTIME_KEYS[@]} -gt 1 ]; then
        echo "${label}: ${SELECTED_PRODUCT} ${SELECTED_VERSION} đã được cài đặt, bỏ qua."
        return 1
      fi
      echo "${SELECTED_PRODUCT} ${SELECTED_VERSION} đã được cài đặt."
      echo ""
      read -r -p "Bạn có muốn cài lại không? (y/N): " confirm
      if [ "$(lowercase "$confirm")" != "y" ]; then
        echo "Đã hủy."
        exit 0
      fi
      echo "Đang cài lại ${SELECTED_PRODUCT}..."
    fi
  fi

  return 0
}

# ============================================================
# B5: TẢI RELEASE + VERIFY CHECKSUM
# ============================================================
download_release() {
  echo "Đang tải ${SELECTED_PRODUCT} ${SELECTED_VERSION}..."

  TMP_DIR=$(mktemp -d)
  local archive_name="ba-kit-${SELECTED_VERSION}.tar.gz"
  ARCHIVE_FILE="${TMP_DIR}/${archive_name}"
  local checksum_name="${archive_name}.sha256"

  if [ "$SELECTED_VISIBILITY" = "public" ]; then
    # Resolve asset URL from already-fetched release JSON
    local release_json
    release_json=$(get_release_json "$SELECTED_VERSION")
    local archive_url
    archive_url=$(echo "$release_json" | jq -r --arg name "$archive_name" '
      .assets[] | select(.name == $name) | .browser_download_url')
    if [ -z "$archive_url" ] || [ "$archive_url" = "null" ]; then
      echo "Lỗi: Không tìm thấy asset ${archive_name} trong release ${SELECTED_VERSION}."
      rm -rf "$TMP_DIR"
      exit 1
    fi

    local checksum_url
    checksum_url=$(echo "$release_json" | jq -r --arg name "$checksum_name" '
      .assets[] | select(.name == $name) | .browser_download_url')
    if [ -z "$checksum_url" ] || [ "$checksum_url" = "null" ]; then
      echo "Lỗi: Release ${SELECTED_VERSION} thiếu checksum bắt buộc; chưa cài file nào."
      rm -rf "$TMP_DIR"
      exit 1
    fi

    curl -fL --retry 2 --retry-delay 1 -o "$ARCHIVE_FILE" "$archive_url" 2>/dev/null || {
      echo "Lỗi: Không thể tải ${SELECTED_PRODUCT} ${SELECTED_VERSION}."
      echo "Vui lòng kiểm tra kết nối mạng và thử lại."
      rm -rf "$TMP_DIR"
      exit 1
    }

    local checksum_file="${TMP_DIR}/checksum.sha256"
    curl -fL -o "$checksum_file" "$checksum_url" 2>/dev/null || {
      echo "Lỗi: Không thể tải checksum."
      rm -rf "$TMP_DIR"
      exit 1
    }

    echo "  Đã tải xong. Đang kiểm tra checksum..."
    local expected actual
    expected=$(awk '{print $1}' "$checksum_file")
    actual=$(sha256 "$ARCHIVE_FILE")
    if [ "$expected" != "$actual" ]; then
      echo "Lỗi: File tải về bị lỗi (checksum không khớp)."
      rm -rf "$TMP_DIR"
      exit 1
    fi
    echo "  Checksum hợp lệ."
  else
    # Private: use gh release download
    require_private_github_access "$SELECTED_PRODUCT"
    if ! gh release download "$SELECTED_VERSION" \
        -R "$SELECTED_REPO" \
        -p "$archive_name" \
        -O "$ARCHIVE_FILE" \
        --clobber 2>/dev/null; then
      echo "Lỗi: Không thể tải ${SELECTED_PRODUCT} ${SELECTED_VERSION}."
      rm -rf "$TMP_DIR"
      exit 1
    fi

    echo "  Đã tải xong. Đang kiểm tra checksum..."
    local checksum_file="${TMP_DIR}/checksum.sha256"
    if gh release download "$SELECTED_VERSION" \
        -R "$SELECTED_REPO" \
        -p "$checksum_name" \
        -O "$checksum_file" \
        --clobber 2>/dev/null; then
      local expected actual
      expected=$(awk '{print $1}' "$checksum_file")
      actual=$(sha256 "$ARCHIVE_FILE")
      if [ "$expected" != "$actual" ]; then
        echo "Lỗi: File tải về bị lỗi (checksum không khớp)."
        rm -rf "$TMP_DIR"
        exit 1
      fi
      echo "  Checksum hợp lệ."
    else
      echo "  Không tìm thấy file checksum, bỏ qua bước kiểm tra."
    fi
  fi
}

# ponytail: enumerate exactly the agents/ or templates/ files THIS install
# placed, from release-manifest.json (the same source merge_files() already
# uses for hash comparison) — not a hardcoded list that drifts every time the
# content package adds/removes files, and not a whole-directory guess that
# risks touching the user's own unrelated agents/templates (which happened
# for real: uninstall's old rm -rf "$INSTALL_DIR/agents" deleted a user's 12
# personal agent files alongside BA-kit's own 4).
_ba_kit_manifest_rel_paths() {
  local manifest_file="$1" prefix="$2"  # prefix: "agents" or "templates"
  [ -f "$manifest_file" ] || return 0
  # ponytail: ltrimstr(), not a sub()/regex with backslashes — Git Bash/MSYS
  # mangles backslash counts in argv passed to native jq.exe on Windows (same
  # class of bug as the POSIX-path issue fixed elsewhere via to_native()), so
  # any \. here silently becomes an "Invalid escape" jq compile error and this
  # whole function returns nothing without visibly failing the install.
  jq -r --arg p "./.claude/$prefix/" '
    keys[] | select(startswith($p)) | ltrimstr("./.claude/")
  ' "$manifest_file" 2>/dev/null
}

# ponytail: copy only the paths BA-kit itself owns/touches, not the whole
# ~/.claude tree. ~/.claude can hold gigabytes of unrelated Claude Code state
# (other skills, cache, session history) — measured 55s+ just to cp -R a real
# user's skills/ dir alone, which made every install/uninstall feel stuck.
_copy_scoped() {
  local src="$1" dst="$2"
  local manifest="$src/ba-kit/release-manifest.json"

  [ -e "$src/ba-kit" ] && { cp -R "$src/ba-kit" "$dst/" 2>/dev/null || true; }
  [ -e "$src/core" ] && { cp -R "$src/core" "$dst/" 2>/dev/null || true; }
  [ -f "$src/settings.json" ] && { cp "$src/settings.json" "$dst/" 2>/dev/null || true; }

  for prefix in agents templates; do
    local rel_paths
    rel_paths=$(_ba_kit_manifest_rel_paths "$manifest" "$prefix")
    [ -z "$rel_paths" ] && continue
    while IFS= read -r rel; do
      [ -z "$rel" ] && continue
      [ -f "$src/$rel" ] || continue
      mkdir -p "$dst/$(dirname "$rel")"
      cp "$src/$rel" "$dst/$rel" 2>/dev/null || true
    done <<< "$rel_paths"
  done

  if [ -d "$src/skills" ]; then
    mkdir -p "$dst/skills"
    for skill in "${BA_KIT_SKILLS[@]}"; do
      [ -d "$src/skills/$skill" ] && { cp -R "$src/skills/$skill" "$dst/skills/" 2>/dev/null || true; }
    done
  fi

  if [ -d "$src/rules" ]; then
    mkdir -p "$dst/rules"
    for rule_file in "${BA_KIT_RULES[@]}"; do
      [ -f "$src/rules/$rule_file" ] && { cp "$src/rules/$rule_file" "$dst/rules/" 2>/dev/null || true; }
    done
  fi

  if [ -d "$src/hooks" ]; then
    mkdir -p "$dst/hooks"
    for hook_file in "$src/hooks"/guardrail-*.sh "$src/hooks/postwrite-guardrail.sh"; do
      [ -f "$hook_file" ] && { cp "$hook_file" "$dst/hooks/" 2>/dev/null || true; }
    done
  fi

  return 0
}

# ponytail: _copy_safe was renamed to _copy_scoped during the 1.1.13 scoped-
# backup fix. This wrapper keeps old call sites working — every call goes
# through the manifest-based scoped copy path, avoiding the original bug
# where backing up the whole ~/.claude tree could copy gigabytes of
# unrelated data (session history, cache, other skills).
_copy_safe() { _copy_scoped "$@"; }

# ============================================================
# B6: BACKUP
# ============================================================
do_backup() {
  local src_dir="$1" backup_dir="$2" keep="${3:-5}"
  if [ -d "$src_dir" ] && [ "$(ls -A "$src_dir" 2>/dev/null)" ]; then
    BACKUP_PATH="${backup_dir}/$(date +%Y-%m-%d-%H%M%S)"
    mkdir -p "$BACKUP_PATH"
    echo "Đang backup ${src_dir} hiện tại vào:"
    echo "  ${BACKUP_PATH}"
    _copy_safe "$src_dir" "$BACKUP_PATH"
    echo "  Backup hoàn tất."
    # ponytail: keep 5 most recent backups, delete older
    prune_backups "$backup_dir" "$keep"
  fi
}

prune_backups() {
  local backup_dir="$1" keep="${2:-5}"
  local count
  count=$(ls -1d "$backup_dir"/*/ 2>/dev/null | wc -l | tr -d ' ')
  if [ "$count" -gt "$keep" ]; then
    local deleted=0
    while IFS= read -r -d '' dir; do
      rm -rf "$dir"
      deleted=$((deleted + 1))
    done < <(ls -1dt "$backup_dir"/*/ 2>/dev/null | tail -n +$((keep + 1)) | tr '\n' '\0')
    echo "  Đã dọn ${deleted} backup cũ (giữ ${keep} gần nhất)."
  fi
}

# ============================================================
# B7: VALIDATE + EXTRACT (via Node archive-helper)
# ============================================================
# Path to the packaged Node helper
ARCHIVE_HELPER="$(dirname "$(realpath "$0" 2>/dev/null || echo "$0")")/lib/archive-helper.js"
# npm global install typically resolves the script dir differently; fallback
if [ ! -f "$ARCHIVE_HELPER" ]; then
  # Try relative to the bin/ba-kit.js dispatcher
  ARCHIVE_HELPER="$(cd "$(dirname "$0")/.." && pwd)/lib/archive-helper.js"
fi
RUNTIME_LIFECYCLE_HELPER="$(dirname "$ARCHIVE_HELPER")/runtime-lifecycle.js"

inspect_archive() {
  echo "Đang kiểm tra archive..."
  local result
  result=$(node "$ARCHIVE_HELPER" inspect \
    --archive "$ARCHIVE_FILE" \
    --profile "$SELECTED_PROFILE" \
    --cli-version "$CLI_VERSION" \
    --runtimes "$(IFS=,; echo "${SELECTED_RUNTIME_KEYS[*]:-claude}")" \
    --selected-product "$SELECTED_PRODUCT_ID" \
    --selected-version "$SELECTED_VERSION" 2>&1) || {
    echo "Lỗi: Archive validation failed."
    local err
    err=$(echo "$result" | jq -r '.error // "unknown error"' 2>/dev/null || echo "$result")
    echo "  $err"
    exit 1
  }
  local ok
  ok=$(echo "$result" | jq -r '.ok' 2>/dev/null)
  if [ "$ok" != "true" ]; then
    echo "Lỗi: Archive không hợp lệ: $result"
    exit 1
  fi
  echo "  Archive hợp lệ."
}

extract_archive() {
  echo "Đang giải nén..."
  EXTRACT_DIR="${TMP_DIR}/extracted"
  mkdir -p "$EXTRACT_DIR"
  node "$ARCHIVE_HELPER" extract \
    --archive "$ARCHIVE_FILE" \
    --profile "$SELECTED_PROFILE" \
    --destination "$EXTRACT_DIR" 2>&1 || {
    echo "Lỗi: Không thể giải nén archive."
    exit 1
  }
  echo "  Giải nén hoàn tất."
}

# Legacy shim
extract_release() {
  inspect_archive
  extract_archive
}

# ============================================================
# B8: MERGE FILE VÀO ~/.claude/
# ============================================================
merge_files() {
  local src="$1"
  local dest="$2"
  local manifest_file="$3"
  local force="${4:-false}"
  local reconciled_file="${5:-}"

  [ ! -d "$src" ] && return

  mkdir -p "$dest"

  local old_manifest="{}"
  [ -f "$manifest_file" ] && old_manifest=$(cat "$manifest_file")

  # release-manifest.json keys are relative to the release build root, e.g.
  # "./.claude/skills/foo/SKILL.md" or "./ba-kit/core/behavior/x.md" — not
  # the bare rel_path this loop computes. Reconstruct the same prefix so
  # old_hash lookups actually hit instead of silently missing every time.
  local key_prefix
  key_prefix="./$(basename "$src")"

  local created=0 updated=0 preserved=0

  while IFS= read -r -d '' src_file; do
    local rel_path="${src_file#$src/}"
    local dest_file="$dest/$rel_path"
    local manifest_key="${key_prefix}/${rel_path}"

    if [ -d "$src_file" ]; then
      continue
    fi

    if [ ! -f "$dest_file" ]; then
      mkdir -p "$(dirname "$dest_file")"
      cp "$src_file" "$dest_file"
      created=$((created + 1))
      [ -n "$reconciled_file" ] && record_reconciled_hash "$reconciled_file" "$manifest_key" "$(sha256 "$src_file")"
      continue
    fi

    if $force; then
      cp "$src_file" "$dest_file"
      updated=$((updated + 1))
      [ -n "$reconciled_file" ] && record_reconciled_hash "$reconciled_file" "$manifest_key" "$(sha256 "$src_file")"
      continue
    fi

    if is_protected "$rel_path"; then
      preserved=$((preserved + 1))
      continue
    fi

    local old_hash new_hash current_hash
    old_hash=$(echo "$old_manifest" | jq -r ".\"$manifest_key\" // empty" 2>/dev/null)
    new_hash=$(sha256 "$src_file")
    current_hash=$(sha256 "$dest_file")

    if [ "$old_hash" = "$current_hash" ] || [ "$new_hash" = "$current_hash" ]; then
      cp "$src_file" "$dest_file"
      updated=$((updated + 1))
      [ -n "$reconciled_file" ] && record_reconciled_hash "$reconciled_file" "$manifest_key" "$new_hash"
    else
      # Preserved: don't let the manifest lie about it. Record the hash
      # actually on disk so a future release can still adopt this file the
      # moment it stops differing, instead of being stuck "preserved"
      # forever against a baseline it was never compared against correctly.
      preserved=$((preserved + 1))
      [ -n "$reconciled_file" ] && record_reconciled_hash "$reconciled_file" "$manifest_key" "$current_hash"
    fi
  done < <(find "$src" -print0)

  echo "  ${created} file mới | ${updated} file cập nhật | ${preserved} file giữ nguyên (đã tùy chỉnh)"
}

record_reconciled_hash() {
  local file="$1" key="$2" hash="$3"
  local tmp
  tmp=$(mktemp)
  jq --arg k "$key" --arg h "$hash" '. + {($k): $h}' "$file" > "$tmp" && mv "$tmp" "$file"
}

is_protected() {
  local path="$1"
  case "$path" in
    .env|.env.*|credentials/*|tokens/*|secrets/*|*.key|*.pem)
      return 0 ;;
  esac
  return 1
}

# ============================================================
# B9: POST-INSTALL
# ============================================================
post_install() {
  local root="$1"
  echo "Đang hoàn tất cài đặt..."

  if [ -f "$EXTRACT_DIR/.local/bin/ba-kit" ]; then
    mkdir -p "$root/ba-kit"
    cp "$EXTRACT_DIR/.local/bin/ba-kit" "$root/ba-kit/ba-kit"
    chmod +x "$root/ba-kit/ba-kit"

    # Remove stale framework binary at ~/.local/bin/ba-kit so it no longer
    # shadows the npm-installed CLI wrapper in PATH.
    if [ -f "$BIN_DIR/ba-kit" ] && ! [ -L "$BIN_DIR/ba-kit" ]; then
      rm -f "$BIN_DIR/ba-kit"
      echo "  Removed stale framework binary at ${BIN_DIR}/ba-kit (was shadowing npm CLI)"
    fi
  fi

  register_hooks "$root"

  if [ -f "$root/ba-kit/scripts/requirements.txt" ]; then
    if command -v python3 &>/dev/null; then
      python3 -m pip install -r "$root/ba-kit/scripts/requirements.txt" --quiet 2>/dev/null || true
    fi
  fi

  if [ -d "$root/ba-kit/core" ]; then
    ln -sfn "$root/ba-kit/core" "$root/core" 2>/dev/null || true
  fi

  echo "  Hoàn tất."
}

register_hooks() {
  local root="$1"
  local settings="$HOME/.claude/settings.json"
  local hooks_dir="$root/hooks"

  [ ! -d "$hooks_dir" ] && return

  refresh_windows_path
  if ! command -v python3 &>/dev/null; then
    auto_install_dep "Python 3" "python3" "python3" "python3" "python" "python3" "Python.Python.3" "python3" "python" || true
  fi
  if ! command -v python3 &>/dev/null; then
    echo "  [CẢNH BÁO] Python3 chưa cài — bỏ qua đăng ký hooks (macOS: brew install python3)."
    return
  fi

  echo "  Dang dang ky hooks..."

  if [ ! -f "$settings" ]; then
    echo '{}' > "$settings"
  fi

  PYTHONIOENCODING=utf-8 python3 << PYEOF
import json, os, re

def to_native(p):
    # bash on Windows (Git Bash/MSYS) hands us POSIX-style paths like
    # /c/Users/... . Native Windows python3 (python.org, not MSYS python)
    # cannot resolve those in open()/os.listdir()/os.path.isfile() — only
    # os.name == "nt" needs the C:/... rewrite; POSIX python passes through.
    if os.name == "nt":
        m = re.match(r"^/([a-zA-Z])/(.*)$", p)
        if m:
            return f"{m.group(1)}:/{m.group(2)}"
    return p

settings_path = to_native("$settings")
hooks_dir = "$hooks_dir"

with open(settings_path) as f:
    settings = json.load(f)

if "hooks" not in settings:
    settings["hooks"] = {}

hooks_obj = settings["hooks"]
hook_count = 0

# Clean old top-level entries from buggy register_hooks
valid_events = {"SessionStart", "PreToolUse", "PostToolUse", "UserPromptSubmit", "Stop"}
for key in list(hooks_obj.keys()):
    if key not in valid_events:
        del hooks_obj[key]

for hook_file in sorted(os.listdir(to_native(hooks_dir))):
    if not hook_file.endswith(".sh"):
        continue
    hook_name = hook_file.replace(".sh", "")
    hook_path = os.path.join(hooks_dir, hook_file)

    if "preflight" in hook_name and "context" not in hook_name:
        event, matcher = "UserPromptSubmit", ""
    elif "audit" in hook_name and "context-audit" in hook_name:
        event, matcher = "Stop", ""
    elif "context-preflight" in hook_name or "preflight-guard" in hook_name:
        event, matcher = "PreToolUse", "Read|Glob"
    elif "context-output" in hook_name or "output-guard" in hook_name:
        event, matcher = "PostToolUse", "Bash|Read|Grep|Glob"
    elif "write-scope" in hook_name:
        event, matcher = "PreToolUse", "Write|Edit"
    elif "postwrite" in hook_name:
        event, matcher = "PostToolUse", "Write|Edit"
    elif "index-validation" in hook_name:
        event, matcher = "PostToolUse", "Write|Edit"
    else:
        continue

    if event not in hooks_obj:
        hooks_obj[event] = []
    if not isinstance(hooks_obj[event], list):
        hooks_obj[event] = []

    entry = {
        "matcher": matcher,
        "hooks": [{
            "type": "command",
            "command": "bash \"" + hook_path + "\""
        }]
    }

    already = False
    for ex in hooks_obj[event]:
        for h in ex.get("hooks", []):
            if hook_name in h.get("command", ""):
                already = True
    if already:
        continue

    hooks_obj[event].append(entry)
    hook_count += 1

# Clean stale hooks pointing to deleted files
for event in valid_events:
    if event not in hooks_obj or not isinstance(hooks_obj[event], list):
        continue
    cleaned = []
    for entry in hooks_obj[event]:
        if not isinstance(entry, dict):
            continue
        ok = False
        for h in entry.get("hooks", []):
            cmd = h.get("command", "")
            m = re.search(r'bash "([^"]+)"', cmd)
            if m and os.path.isfile(to_native(m.group(1))):
                ok = True
                break
        if ok:
            cleaned.append(entry)
    hooks_obj[event] = cleaned

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2, ensure_ascii=False)
    f.write("\n")

print(f"  Registered {hook_count} hooks")
PYEOF
}

# Remove stale ba-kit hook entries from settings.json — called during uninstall
clean_hooks_json() {
  local settings="$HOME/.claude/settings.json"
  [ ! -f "$settings" ] && return

  refresh_windows_path
  if ! command -v python3 &>/dev/null; then
    auto_install_dep "Python 3" "python3" "python3" "python3" "python" "python3" "Python.Python.3" "python3" "python" || true
  fi
  if ! command -v python3 &>/dev/null; then
    echo "  [CẢNH BÁO] Python3 chưa cài — bỏ qua dọn hooks cũ."
    return
  fi

  PYTHONIOENCODING=utf-8 python3 << PYEOF
import json, os, re

def to_native(p):
    # See register_hooks() to_native() — same POSIX-vs-native-Windows-python
    # path mismatch applies here.
    if os.name == "nt":
        m = re.match(r"^/([a-zA-Z])/(.*)$", p)
        if m:
            return f"{m.group(1)}:/{m.group(2)}"
    return p

settings_path = to_native("$settings")

with open(settings_path) as f:
    settings = json.load(f)

if "hooks" not in settings:
    exit(0)

hooks_obj = settings["hooks"]
valid_events = {"SessionStart", "PreToolUse", "PostToolUse", "UserPromptSubmit", "Stop"}
removed = 0

for event in valid_events:
    if event not in hooks_obj or not isinstance(hooks_obj[event], list):
        continue
    cleaned = []
    for entry in hooks_obj[event]:
        if not isinstance(entry, dict):
            continue
        ok = False
        for h in entry.get("hooks", []):
            cmd = h.get("command", "")
            m = re.search(r'bash "([^"]+)"', cmd)
            if m and os.path.isfile(to_native(m.group(1))):
                ok = True
                break
        if ok:
            cleaned.append(entry)
        else:
            removed += 1
    hooks_obj[event] = cleaned

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2, ensure_ascii=False)
    f.write("\n")

if removed > 0:
    print(f"  Dọn dẹp {removed} stale hook entries")
PYEOF
}


