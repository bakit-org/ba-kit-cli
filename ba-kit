#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# BA-kit CLI — AI-powered Business Analyst toolkit for Claude Code
# ============================================================

# === CONFIG ===
REPO="bakit-org/bakit"
INSTALL_DIR="$HOME/.claude"
BACKUP_DIR="$INSTALL_DIR/backups"
VERSION_FILE="$INSTALL_DIR/ba-kit/VERSION"
MANIFEST_FILE="$INSTALL_DIR/ba-kit/release-manifest.json"
BIN_DIR="$HOME/.local/bin"

# === ENTRY POINT ===
# ponytail: portable lowercase — macOS bash 3.2 doesn't support ${var,,}
lowercase() { echo "$1" | tr '[:upper:]' '[:lower:]'; }
main() {
  case "${1:-}" in
    install)   shift; cmd_install "$@" ;;
    update)    cmd_update ;;
    doctor)    cmd_doctor ;;
    version)   cmd_version ;;
    uninstall) cmd_uninstall ;;
    help|--help|-h)
      usage
      ;;
    *)
      echo "BA-kit CLI — AI-powered Business Analyst toolkit for Claude Code"
      echo ""
      echo "Commands:"
      echo "  ba-kit install              Cài đặt BA-kit lần đầu"
      echo "  ba-kit install --version X  Cài version cụ thể (vd: v1.2.0)"
      echo "  ba-kit update               Cập nhật lên phiên bản mới nhất"
      echo "  ba-kit doctor               Kiểm tra trạng thái cài đặt"
      echo "  ba-kit version              Hiển thị phiên bản đã cài"
      echo "  ba-kit uninstall            Gỡ cài đặt (có backup)"
      echo ""
      echo "Mua BA-kit: https://polar.sh/checkout/polar_c_Bd8xfL8VTBQtYpol2MdbS2M5acEFMsjKmDFec0bYVGF"
      ;;
  esac
}

usage() {
  echo "BA-kit CLI"
  echo ""
  echo "Commands:"
  echo "  ba-kit install              Cài đặt BA-kit lần đầu"
  echo "  ba-kit install --version X  Cài version cụ thể"
  echo "  ba-kit update               Cập nhật lên phiên bản mới nhất"
  echo "  ba-kit doctor               Kiểm tra trạng thái cài đặt"
  echo "  ba-kit version              Hiển thị phiên bản đã cài"
  echo "  ba-kit uninstall            Gỡ cài đặt (có backup)"
  echo ""
  echo "Mua BA-kit: https://polar.sh/checkout/polar_c_Bd8xfL8VTBQtYpol2MdbS2M5acEFMsjKmDFec0bYVGF"
}

# ============================================================
# B1: KIỂM TRA PREREQUISITES
# ============================================================
