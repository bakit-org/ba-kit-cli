# Parses "$1" (comma-list or empty) into global SELECTED_RUNTIME_KEYS array.
# Exits 1 on unknown key or empty token. Default (empty input) = claude only.
parse_runtime_flag() {
  # No default here — callers decide the default (cmd_install passes
  # "claude" when --runtime is omitted; cmd_uninstall skips calling this
  # entirely when --runtime is omitted, using auto-detect instead). An
  # explicitly empty "$1" (e.g. `--runtime ""`) is always an error.
  local raw="$1"
  SELECTED_RUNTIME_KEYS=()
  if [ -z "$raw" ]; then
    echo "Lỗi: --runtime chứa giá trị rỗng."
    echo "Runtime hợp lệ: ${RUNTIME_KEYS[*]}"
    exit 1
  fi
  local IFS=','
  local -a tokens=($raw)
  local seen=""
  for tok in "${tokens[@]}"; do
    tok="$(echo "$tok" | tr -d '[:space:]')"
    if [ -z "$tok" ]; then
      echo "Lỗi: --runtime chứa giá trị rỗng."
      echo "Runtime hợp lệ: ${RUNTIME_KEYS[*]}"
      exit 1
    fi
    if ! runtime_index_for_key "$tok" >/dev/null; then
      echo "Lỗi: runtime '$tok' không hợp lệ."
      echo "Runtime hợp lệ: ${RUNTIME_KEYS[*]}"
      exit 1
    fi
    case ",$seen," in
      *",$tok,"*) continue ;;
    esac
    seen="${seen:+$seen,}$tok"
    SELECTED_RUNTIME_KEYS+=("$tok")
  done
}

