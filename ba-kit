# B7: GIẢI NÉN
# ============================================================
extract_release() {
  echo "Đang giải nén..."

  EXTRACT_DIR="${TMP_DIR}/extracted"
  mkdir -p "$EXTRACT_DIR"
  tar -xzf "$ARCHIVE_FILE" -C "$EXTRACT_DIR"

  echo "  Giải nén hoàn tất."
}

# ============================================================
# B8: MERGE FILE VÀO ~/.claude/
# ============================================================
merge_files() {
  local src="$1"
  local dest="$2"
  local manifest_file="$3"
  local force="${4:-false}"

  [ ! -d "$src" ] && return

  mkdir -p "$dest"

  local old_manifest="{}"
  [ -f "$manifest_file" ] && old_manifest=$(cat "$manifest_file")

  local new_manifest="{}"
  local parent_manifest
  parent_manifest=$(dirname "$src")/release-manifest.json
  [ -f "$parent_manifest" ] && new_manifest=$(cat "$parent_manifest")

  local created=0 updated=0 preserved=0

  while IFS= read -r -d '' src_file; do
    local rel_path="${src_file#$src/}"
    local dest_file="$dest/$rel_path"

    if [ -d "$src_file" ]; then
      continue
    fi

    if [ ! -f "$dest_file" ]; then
      mkdir -p "$(dirname "$dest_file")"
      cp "$src_file" "$dest_file"
      created=$((created + 1))
      continue
    fi

    if $force; then
      cp "$src_file" "$dest_file"
      updated=$((updated + 1))
      continue
    fi

    if is_protected "$rel_path"; then
      preserved=$((preserved + 1))
      continue
    fi

    local old_hash new_hash current_hash
    old_hash=$(echo "$old_manifest" | jq -r ".\"$rel_path\" // empty" 2>/dev/null)
    new_hash=$(sha256 "$src_file")
    current_hash=$(sha256 "$dest_file")

    if [ "$old_hash" = "$current_hash" ] || [ "$new_hash" = "$current_hash" ]; then
      cp "$src_file" "$dest_file"
      updated=$((updated + 1))
    else
      preserved=$((preserved + 1))
    fi
  done < <(find "$src" -print0)

  echo "  ${created} file mới | ${updated} file cập nhật | ${preserved} file giữ nguyên (đã tùy chỉnh)"
}

is_protected() {
  local path="$1"
  case "$path" in
    .env|.env.*|credentials/*|tokens/*|secrets/*|*.key|*.pem)
      return 0 ;;
  esac
  return 1
}

# ============================================================
# B9: POST-INSTALL
# ============================================================
post_install() {
  local root="$1"
  echo "Đang hoàn tất cài đặt..."

  if [ -f "$EXTRACT_DIR/.local/bin/ba-kit" ]; then
    mkdir -p "$root/ba-kit"
    cp "$EXTRACT_DIR/.local/bin/ba-kit" "$root/ba-kit/ba-kit"
    chmod +x "$root/ba-kit/ba-kit"

    # Remove stale framework binary at ~/.local/bin/ba-kit so it no longer
    # shadows the npm-installed CLI wrapper in PATH.
    if [ -f "$BIN_DIR/ba-kit" ] && ! [ -L "$BIN_DIR/ba-kit" ]; then
      rm -f "$BIN_DIR/ba-kit"
      echo "  Removed stale framework binary at ${BIN_DIR}/ba-kit (was shadowing npm CLI)"
    fi
  fi

  register_hooks "$root"

  if [ -f "$root/ba-kit/scripts/requirements.txt" ]; then
    if command -v python3 &>/dev/null; then
      python3 -m pip install -r "$root/ba-kit/scripts/requirements.txt" --quiet 2>/dev/null || true
    fi
  fi

  if [ -d "$root/ba-kit" ]; then
    ln -sfn "$root/ba-kit" "$root/core" 2>/dev/null || true
  fi

  echo "  Hoàn tất."
}

register_hooks() {
  local root="$1"
  local settings="$HOME/.claude/settings.json"
  local hooks_dir="$root/hooks"

  [ ! -d "$hooks_dir" ] && return

  echo "  Dang dang ky hooks..."

  if [ ! -f "$settings" ]; then
    echo '{}' > "$settings"
  fi

  PYTHONIOENCODING=utf-8 python3 << PYEOF
import json, os, re

def to_native(p):
    # bash on Windows (Git Bash/MSYS) hands us POSIX-style paths like
    # /c/Users/... . Native Windows python3 (python.org, not MSYS python)
    # cannot resolve those in open()/os.listdir()/os.path.isfile() — only
    # os.name == "nt" needs the C:/... rewrite; POSIX python passes through.
    if os.name == "nt":
        m = re.match(r"^/([a-zA-Z])/(.*)$", p)
        if m:
            return f"{m.group(1)}:/{m.group(2)}"
    return p

settings_path = to_native("$settings")
hooks_dir = "$hooks_dir"

with open(settings_path) as f:
    settings = json.load(f)

if "hooks" not in settings:
    settings["hooks"] = {}

hooks_obj = settings["hooks"]
hook_count = 0

# Clean old top-level entries from buggy register_hooks
valid_events = {"SessionStart", "PreToolUse", "PostToolUse", "UserPromptSubmit", "Stop"}
for key in list(hooks_obj.keys()):
    if key not in valid_events:
        del hooks_obj[key]

for hook_file in sorted(os.listdir(to_native(hooks_dir))):
    if not hook_file.endswith(".sh"):
        continue
    hook_name = hook_file.replace(".sh", "")
    hook_path = os.path.join(hooks_dir, hook_file)

    if "preflight" in hook_name and "context" not in hook_name:
        event, matcher = "UserPromptSubmit", ""
    elif "audit" in hook_name and "context-audit" in hook_name:
        event, matcher = "Stop", ""
    elif "context-preflight" in hook_name or "preflight-guard" in hook_name:
        event, matcher = "PreToolUse", "Read|Glob"
    elif "context-output" in hook_name or "output-guard" in hook_name:
        event, matcher = "PostToolUse", "Bash|Read|Grep|Glob"
    elif "write-scope" in hook_name:
        event, matcher = "PreToolUse", "Write|Edit"
    elif "postwrite" in hook_name:
        event, matcher = "PostToolUse", "Write|Edit"
    elif "index-validation" in hook_name:
        event, matcher = "PostToolUse", "Write|Edit"
    else:
        continue

    if event not in hooks_obj:
        hooks_obj[event] = []
    if not isinstance(hooks_obj[event], list):
        hooks_obj[event] = []

    entry = {
        "matcher": matcher,
        "hooks": [{
            "type": "command",
            "command": "bash \"" + hook_path + "\""
        }]
    }

    already = False
    for ex in hooks_obj[event]:
        for h in ex.get("hooks", []):
            if hook_name in h.get("command", ""):
                already = True
    if already:
        continue

    hooks_obj[event].append(entry)
    hook_count += 1

# Clean stale hooks pointing to deleted files
for event in valid_events:
    if event not in hooks_obj or not isinstance(hooks_obj[event], list):
        continue
    cleaned = []
    for entry in hooks_obj[event]:
        if not isinstance(entry, dict):
            continue
        ok = False
        for h in entry.get("hooks", []):
            cmd = h.get("command", "")
            m = re.search(r'bash "([^"]+)"', cmd)
            if m and os.path.isfile(to_native(m.group(1))):
                ok = True
                break
        if ok:
            cleaned.append(entry)
    hooks_obj[event] = cleaned

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2, ensure_ascii=False)
    f.write("\n")

print(f"  Registered {hook_count} hooks")
PYEOF
}

# Remove stale ba-kit hook entries from settings.json — called during uninstall
clean_hooks_json() {
  local settings="$HOME/.claude/settings.json"
  [ ! -f "$settings" ] && return

  PYTHONIOENCODING=utf-8 python3 << PYEOF
import json, os, re

def to_native(p):
    # See register_hooks() to_native() — same POSIX-vs-native-Windows-python
    # path mismatch applies here.
    if os.name == "nt":
        m = re.match(r"^/([a-zA-Z])/(.*)$", p)
        if m:
            return f"{m.group(1)}:/{m.group(2)}"
    return p

settings_path = to_native("$settings")

with open(settings_path) as f:
    settings = json.load(f)

if "hooks" not in settings:
    exit(0)

hooks_obj = settings["hooks"]
valid_events = {"SessionStart", "PreToolUse", "PostToolUse", "UserPromptSubmit", "Stop"}
removed = 0

for event in valid_events:
    if event not in hooks_obj or not isinstance(hooks_obj[event], list):
        continue
    cleaned = []
    for entry in hooks_obj[event]:
        if not isinstance(entry, dict):
            continue
        ok = False
        for h in entry.get("hooks", []):
            cmd = h.get("command", "")
            m = re.search(r'bash "([^"]+)"', cmd)
            if m and os.path.isfile(to_native(m.group(1))):
                ok = True
                break
        if ok:
            cleaned.append(entry)
        else:
            removed += 1
    hooks_obj[event] = cleaned

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2, ensure_ascii=False)
    f.write("\n")

if removed > 0:
    print(f"  Dọn dẹp {removed} stale hook entries")
PYEOF
}


# ============================================================
# B10: LƯU VERSION + PRODUCT + MANIFEST
# ============================================================
save_state() {
  local version_file="$1" product_file="$2" manifest_file="$3" extract_dir="$4"
  echo "Đang lưu thông tin..."

  mkdir -p "$(dirname "$version_file")"
  echo "$SELECTED_VERSION" > "$version_file"
  echo "$SELECTED_PRODUCT" > "$product_file"

  if [ -f "$extract_dir/release-manifest.json" ]; then
    cp "$extract_dir/release-manifest.json" "$manifest_file"
  fi
}

# ============================================================
# B11: DỌN DẸP
# ============================================================
cleanup() {
  if [ -n "${TMP_DIR:-}" ] && [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
}

# ============================================================
# B12: HIỂN THỊ KẾT QUẢ
# ============================================================
show_result() {
  # $@ = processed runtime keys
  echo ""
  echo "=============================================="
  echo "  CÀI ĐẶT THÀNH CÔNG!"
  echo "=============================================="

  for key in "$@"; do
    local root scope label
    root=$(runtime_root_for_key "$key")
    scope=$(runtime_scope_for_key "$key")
    label=$(runtime_label_for_key "$key")

    echo ""
    echo "  -- ${label} (${root}) --"
    echo "  Sản phẩm:   ${SELECTED_PRODUCT}"
    echo "  Phiên bản:  ${SELECTED_VERSION}"

    if [ "$scope" = "full" ]; then
      local skill_count agent_count template_count hook_count
      skill_count=$(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ')
      agent_count=$(ls -1 "$root/agents/" 2>/dev/null | wc -l | tr -d ' ')
      template_count=$(ls -1 "$root/templates/" 2>/dev/null | wc -l | tr -d ' ')
      hook_count=$(ls -1 "$root/hooks/" 2>/dev/null | wc -l | tr -d ' ')
      echo "  Skills:     ${skill_count}"
      echo "  Agents:     ${agent_count}"
      echo "  Templates:  ${template_count}"
      echo "  Hooks:      ${hook_count}"
    else
      local skill_count
      skill_count=$(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ')
      echo "  Skills:     ${skill_count}"
    fi

    local backup_dir
    backup_dir=$(runtime_backup_dir "$key")
    local latest_backup
    latest_backup=$(ls -1dt "$backup_dir"/*/ 2>/dev/null | head -1)
    if [ -n "$latest_backup" ]; then
      echo "  Backup cũ:  ${latest_backup}"
    fi
  done

  echo ""
  echo "  Bắt đầu sử dụng:"
  echo "    Vào Claude Code (/claude trong Terminal)"
  echo "    Gõ /ba-start để bắt đầu dự án BA"
  echo ""
  echo "  Cập nhật sau này:"
  echo "    ba-kit update"
  echo ""
  echo "  Kiểm tra sức khỏe:"
  echo "    ba-kit doctor"
  echo "=============================================="
}

# ============================================================
# COMMAND: ba-kit install
# ============================================================
cmd_install() {
  local target_version="latest"
  local target_runtime="claude"

  while [ $# -gt 0 ]; do
    case "$1" in
      --version)
        target_version="$2"
        shift 2
        ;;
      --runtime)
        target_runtime="$2"
        shift 2
        ;;
      *)
        echo "Không hiểu tham số: $1"
        echo "Dùng: ba-kit install [--version v1.2.0] [--runtime claude,codex,agy]"
        exit 1
        ;;
    esac
  done

  parse_runtime_flag "$target_runtime"  # sets SELECTED_RUNTIME_KEYS, validates

  echo ""
  echo "=============================================="
  echo "  BA-KIT INSTALL"
  echo "=============================================="
  echo ""

  check_prereqs                         # B1
  select_product                        # B2: probe repos + select
  select_version "$target_version"      # B3

  # B4: prevent install over different product, per selected runtime.
  # Skip runtimes already at the target version (silently if 2+ selected).
  local -a RUNTIMES_TO_PROCESS=()
  for key in "${SELECTED_RUNTIME_KEYS[@]}"; do
    if check_cross_product_for_runtime "$key"; then
      RUNTIMES_TO_PROCESS+=("$key")
    fi
  done
  if [ ${#RUNTIMES_TO_PROCESS[@]} -eq 0 ]; then
    echo "Không có runtime nào cần cài/cập nhật."
    exit 0
  fi

  download_release                      # B5
  extract_release                       # B7

  echo "Đang cài đặt files..."

  for key in "${RUNTIMES_TO_PROCESS[@]}"; do
    local root scope label
    root=$(runtime_root_for_key "$key")
    scope=$(runtime_scope_for_key "$key")
    label=$(runtime_label_for_key "$key")

    echo ""
    echo "-- ${label} (${root}) --"

    if [ "$scope" = "full" ]; then
      do_backup "$root" "$(runtime_backup_dir "$key")"                          # B6
      merge_files "$EXTRACT_DIR/.claude" "$root" "$(runtime_manifest_file "$key")"           # B8a
      merge_files "$EXTRACT_DIR/ba-kit" "$root/ba-kit" "$(runtime_manifest_file "$key")" true # B8b
      post_install "$root"             # B9
    else
      do_backup "$root/skills" "$(runtime_backup_dir "$key")"                   # B6
      merge_files "$EXTRACT_DIR/.claude/skills" "$root/skills" "$(runtime_manifest_file "$key")" # B8
    fi

    save_state "$(runtime_version_file "$key")" "$(runtime_product_file "$key")" \
               "$(runtime_manifest_file "$key")" "$EXTRACT_DIR"                 # B10
  done

  cleanup                               # B11
  show_result "${RUNTIMES_TO_PROCESS[@]}"  # B12
}

# ============================================================
# COMMAND: ba-kit update
# ============================================================
cmd_update() {
  echo ""
  echo "=============================================="
  echo "  BA-KIT UPDATE"
  echo "=============================================="
  echo ""

  check_prereqs

  # Auto-detect every runtime with existing state — no --runtime flag.
  local -a DETECTED_KEYS=()
  for key in "${RUNTIME_KEYS[@]}"; do
    [ -f "$(runtime_version_file "$key")" ] && DETECTED_KEYS+=("$key")
  done

  if [ ${#DETECTED_KEYS[@]} -eq 0 ]; then
    echo "BA-kit chưa được cài đặt."
    echo "Chạy: ba-kit install"
    exit 1
  fi

  # Group detected runtimes by their recorded product (bash 3.2: parallel
  # arrays, not associative — small N so a linear scan is fine).
  local -a GROUP_LABELS=() GROUP_MEMBERS=()
  for key in "${DETECTED_KEYS[@]}"; do
    local product
    product=$(cat "$(runtime_product_file "$key")" 2>/dev/null)
    [ -z "$product" ] && continue
    local idx=-1
    for i in "${!GROUP_LABELS[@]}"; do
      if [ "${GROUP_LABELS[$i]}" = "$product" ]; then
        idx=$i
        break
      fi
    done
    if [ "$idx" -eq -1 ]; then
      GROUP_LABELS+=("$product")
      GROUP_MEMBERS+=("$key")
    else
      GROUP_MEMBERS[$idx]="${GROUP_MEMBERS[$idx]},${key}"
    fi
  done

  if [ ${#GROUP_LABELS[@]} -gt 1 ]; then
    echo "Đang cập nhật ${#GROUP_LABELS[@]} nhóm sản phẩm riêng biệt..."
    echo ""
  fi

  local -a ALL_PROCESSED=()

  for gi in "${!GROUP_LABELS[@]}"; do
    local group_product="${GROUP_LABELS[$gi]}"
    local -a group_keys
    IFS=',' read -r -a group_keys <<< "${GROUP_MEMBERS[$gi]}"

    echo "Sản phẩm: ${group_product}"
    for key in "${group_keys[@]}"; do
      local cur label
      cur=$(cat "$(runtime_version_file "$key")")
      label=$(runtime_label_for_key "$key")
      echo "  ${label}: ${cur}"
    done

    local found=false repo="" purl=""
    for i in "${!PRODUCT_NAMES[@]}"; do
      if [ "${PRODUCT_NAMES[$i]}" = "$group_product" ]; then
        repo="${PRODUCT_REPOS[$i]}"
        purl="${PRODUCT_URLS[$i]}"
        found=true
        break
      fi
    done

    if ! $found; then
      echo "Lỗi: Sản phẩm '${group_product}' không được hỗ trợ."
      echo "Vui lòng cài lại: ba-kit install --runtime ${group_keys[*]}"
      exit 1
    fi

    # Verify still have access
    if ! gh api "repos/${repo}" --jq '.private' &>/dev/null 2>&1; then
      echo ""
      echo "=============================================="
      echo "  KHÔNG CÓ QUYỀN TRUY CẬP"
      echo "=============================================="
      echo ""
      echo "Quyền truy cập ${group_product} đã bị thu hồi."
      echo "File đã cài vẫn dùng được nhưng không thể cập nhật."
      echo "Mua lại: ${purl:-https://polar.sh/bakit-org/products}"
      echo "=============================================="
      exit 1
    fi

    local latest
    latest=$(gh api "repos/${repo}/releases/latest" --jq '.tag_name' 2>/dev/null) || {
      echo "Lỗi: Không thể kiểm tra phiên bản mới."
      exit 1
    }
    echo "Phiên bản mới nhất: ${latest}"

    # Skip the whole group only if every member is already at latest
    local all_latest=true
    for key in "${group_keys[@]}"; do
      local cur
      cur=$(cat "$(runtime_version_file "$key")")
      if [ "$cur" != "$latest" ]; then
        all_latest=false
        break
      fi
    done
    if $all_latest; then
      echo "Đang dùng phiên bản mới nhất cho nhóm này."
      echo ""
      continue
    fi

    local changelog
    changelog=$(gh api "repos/${repo}/releases/latest" --jq '.body // ""' 2>/dev/null)
    echo ""
    echo "Thay đổi trong ${latest}:"
    echo "----------------------------------------"
    echo "${changelog:-}" | head -30
    echo "----------------------------------------"
    echo ""

    read -r -p "Cập nhật lên ${latest}? (Y/n): " confirm
    if [ "$(lowercase "$confirm")" = "n" ]; then
      echo "Đã hủy nhóm ${group_product}."
      echo ""
      continue
    fi

    echo ""
    echo "Đang cập nhật..."
    SELECTED_PRODUCT="$group_product"
    SELECTED_VERSION="$latest"
    RELEASE_NOTES="$changelog"
    download_release
    extract_release

    echo "Đang cập nhật files..."

    for key in "${group_keys[@]}"; do
      local root scope label
      root=$(runtime_root_for_key "$key")
      scope=$(runtime_scope_for_key "$key")
      label=$(runtime_label_for_key "$key")

      echo ""
      echo "-- ${label} (${root}) --"

      if [ "$scope" = "full" ]; then
        do_backup "$root" "$(runtime_backup_dir "$key")"
        merge_files "$EXTRACT_DIR/.claude" "$root" "$(runtime_manifest_file "$key")"
        merge_files "$EXTRACT_DIR/ba-kit" "$root/ba-kit" "$(runtime_manifest_file "$key")" true
        post_install "$root"
      else
        do_backup "$root/skills" "$(runtime_backup_dir "$key")"
        merge_files "$EXTRACT_DIR/.claude/skills" "$root/skills" "$(runtime_manifest_file "$key")"
      fi

      save_state "$(runtime_version_file "$key")" "$(runtime_product_file "$key")" \
                 "$(runtime_manifest_file "$key")" "$EXTRACT_DIR"
      ALL_PROCESSED+=("$key")
    done

    cleanup
    echo ""
  done

  if [ ${#ALL_PROCESSED[@]} -eq 0 ]; then
    exit 0
  fi

  show_result "${ALL_PROCESSED[@]}"
}

# ============================================================
# COMMAND: ba-kit doctor
# ============================================================
cmd_doctor() {
  echo ""
  echo "=============================================="
  echo "  BA-KIT HEALTH CHECK"
  echo "=============================================="
  echo ""

  # Product + Version — per runtime
  local any_installed=false
  for key in "${RUNTIME_KEYS[@]}"; do
    local label pfile vfile
    label=$(runtime_label_for_key "$key")
    pfile=$(runtime_product_file "$key")
    vfile=$(runtime_version_file "$key")
    if [ -f "$pfile" ] && [ -f "$vfile" ]; then
      echo "[OK]   ${label}: $(cat "$pfile") $(cat "$vfile")"
      any_installed=true
    elif [ -f "$vfile" ]; then
      echo "[OK]   ${label}: $(cat "$vfile") (chưa có PRODUCT file — cài lại để cập nhật)"
      any_installed=true
    else
      echo "[CHƯA] ${label}: chưa được cài đặt"
    fi
  done
  if ! $any_installed; then
    echo "       Chạy: ba-kit install"
  fi

  # gh CLI
  if command -v gh &>/dev/null; then
    local gh_ver
    gh_ver=$(gh --version 2>/dev/null | head -1 || echo "unknown")
    echo "[OK]   GitHub CLI: ${gh_ver}"
  else
    echo "[THIẾU] GitHub CLI chưa cài"
    echo "        macOS: brew install gh"
    echo "        Khác: https://cli.github.com"
  fi

  # gh auth
  if gh auth status -h github.com &>/dev/null 2>&1; then
    local gh_user
    gh_user=$(gh api user --jq '.login' 2>/dev/null || echo "unknown")
    echo "[OK]   GitHub auth: ${gh_user}"
  else
    echo "[THIẾU] GitHub chưa đăng nhập"
    echo "        Chạy: gh auth login"
  fi

  # Access check for each product
  echo ""
  echo "Quyền truy cập sản phẩm:"
  for i in "${!PRODUCT_NAMES[@]}"; do
    local name="${PRODUCT_NAMES[$i]}"
    local repo="${PRODUCT_REPOS[$i]}"
    local url="${PRODUCT_URLS[$i]}"
    if gh api "repos/${repo}" --jq '.private' &>/dev/null 2>&1; then
      echo "  [OK]   ${name} — có quyền truy cập"
    else
      echo "  [THIẾU] ${name} — chưa có quyền (mua: ${url})"
    fi
  done

  # Python
  if command -v python3 &>/dev/null; then
    local py_ver
    py_ver=$(python3 --version 2>&1)
    echo ""
    echo "[OK]   Python: ${py_ver}"
  else
    echo ""
    echo "[CẢNH BÁO] Python3 chưa cài (cần cho guardrail scripts)"
  fi

  # Components — per runtime, scoped to what that runtime actually gets
  echo ""
  echo "Components đã cài:"
  for key in "${RUNTIME_KEYS[@]}"; do
    local root scope label
    root=$(runtime_root_for_key "$key")
    scope=$(runtime_scope_for_key "$key")
    label=$(runtime_label_for_key "$key")
    [ ! -f "$(runtime_version_file "$key")" ] && continue

    echo "  ${label}:"
    if [ "$scope" = "full" ]; then
      [ -d "$root/skills" ]    && echo "    Skills:    $(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ') thư mục"
      [ -d "$root/agents" ]    && echo "    Agents:    $(ls -1 "$root/agents/" 2>/dev/null | wc -l | tr -d ' ') file"
      [ -d "$root/templates" ] && echo "    Templates: $(ls -1 "$root/templates/" 2>/dev/null | wc -l | tr -d ' ') file"
      [ -d "$root/hooks" ]     && echo "    Hooks:     $(ls -1 "$root/hooks/" 2>/dev/null | wc -l | tr -d ' ') file"
      [ -d "$root/ba-kit" ]    && echo "    Core:      ${root}/ba-kit/"
    else
      [ -d "$root/skills" ] && echo "    Skills: $(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ') thư mục"
    fi
  done

  echo ""
}

# ============================================================
# COMMAND: ba-kit version
# ============================================================
cmd_version() {
  echo "BA-kit CLI: v${CLI_VERSION}"
  for key in "${RUNTIME_KEYS[@]}"; do
    local label pfile vfile
    label=$(runtime_label_for_key "$key")
    pfile=$(runtime_product_file "$key")
    vfile=$(runtime_version_file "$key")
    if [ -f "$pfile" ] && [ -f "$vfile" ]; then
      echo "  ${label}: $(cat "$pfile") $(cat "$vfile")"
    elif [ -f "$vfile" ]; then
      echo "  ${label}: $(cat "$vfile")"
    else
      echo "  ${label}: (chưa cài)"
    fi
  done
}

# ============================================================
# COMMAND: ba-kit uninstall
# ============================================================
cmd_uninstall() {
  local target_runtime=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --runtime)
        target_runtime="$2"
        shift 2
        ;;
      *)
        echo "Không hiểu tham số: $1"
        echo "Dùng: ba-kit uninstall [--runtime claude,codex,agy]"
        exit 1
        ;;
    esac
  done

  # No flag = auto-detect every runtime with existing state (backward
  # compatible: existing users only ever have claude state, so this finds
  # exactly claude, same as today).
  local -a TARGET_RUNTIME_KEYS=()
  if [ -n "$target_runtime" ]; then
    parse_runtime_flag "$target_runtime"
    TARGET_RUNTIME_KEYS=("${SELECTED_RUNTIME_KEYS[@]}")
  else
    for key in "${RUNTIME_KEYS[@]}"; do
      [ -f "$(runtime_version_file "$key")" ] && TARGET_RUNTIME_KEYS+=("$key")
    done
  fi

  if [ ${#TARGET_RUNTIME_KEYS[@]} -eq 0 ]; then
    echo "Không có runtime nào đã cài."
    exit 0
  fi

  echo ""
  echo "=============================================="
  echo "  GỠ CÀI ĐẶT"
  echo "=============================================="
  echo ""
  echo "Sẽ gỡ các runtime sau (có backup trước khi xóa):"
  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    local label root pfile vfile product version
    label=$(runtime_label_for_key "$key")
    root=$(runtime_root_for_key "$key")
    pfile=$(runtime_product_file "$key")
    vfile=$(runtime_version_file "$key")
    product="(không rõ)"; version="(không rõ)"
    [ -f "$pfile" ] && product=$(cat "$pfile")
    [ -f "$vfile" ] && version=$(cat "$vfile")
    echo "  - ${label} (${root}): ${product} ${version}"
  done
  echo ""

  read -r -p "Bạn có chắc muốn tiếp tục? (y/N): " confirm
  if [ "$(lowercase "$confirm")" != "y" ]; then
    echo "Đã hủy."
    exit 0
  fi

  echo ""

  local has_claude=false
  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    [ "$key" = "claude" ] && has_claude=true
  done

  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    local root scope label backup_dir backup_path
    root=$(runtime_root_for_key "$key")
    scope=$(runtime_scope_for_key "$key")
    label=$(runtime_label_for_key "$key")
    backup_dir=$(runtime_backup_dir "$key")
    backup_path="${backup_dir}/pre-uninstall-$(date +%Y-%m-%d-%H%M%S)"
    echo "-- ${label} (${root}) --"

    if [ "$scope" = "full" ]; then
      mkdir -p "$backup_path"
      if [ -d "$root" ]; then
        _copy_scoped "$root" "$backup_path"
        echo "Đã backup vào: ${backup_path}"
      fi

      for skill in "${BA_KIT_SKILLS[@]}"; do
        rm -rf "$root/skills/$skill" 2>/dev/null || true
      done

      local agent_rel_paths templates_rel_paths
      agent_rel_paths=$(_ba_kit_manifest_rel_paths "$(runtime_manifest_file "$key")" agents)
      templates_rel_paths=$(_ba_kit_manifest_rel_paths "$(runtime_manifest_file "$key")" templates)

      if [ -n "$agent_rel_paths" ]; then
        while IFS= read -r rel; do
          [ -n "$rel" ] && rm -f "$root/$rel" 2>/dev/null || true
        done <<< "$agent_rel_paths"
      fi

      for rule_file in "${BA_KIT_RULES[@]}"; do
        rm -f "$root/rules/$rule_file" 2>/dev/null || true
      done

      if [ -n "$templates_rel_paths" ]; then
        while IFS= read -r rel; do
          [ -n "$rel" ] && rm -f "$root/$rel" 2>/dev/null || true
        done <<< "$templates_rel_paths"
        find "$root/templates" -mindepth 1 -type d -empty -delete 2>/dev/null || true
      fi

      rm -rf "$root/ba-kit" 2>/dev/null || true
      rm -f "$root/core" 2>/dev/null || true
      rm -f "$root/hooks"/guardrail-*.sh 2>/dev/null || true
      rm -f "$root/hooks"/postwrite-guardrail.sh 2>/dev/null || true
      rm -f "$BIN_DIR/ba-kit" 2>/dev/null || true
    else
      # Skills-only runtime — never touch anything under $root besides
      # skills/<name> and ba-kit/ (the rest is the user's own tool config).
      if [ -d "$root/skills" ]; then
        mkdir -p "$backup_path"
        _copy_safe "$root/skills" "$backup_path"
        echo "Đã backup vào: ${backup_path}"
      fi

      for skill in "${BA_KIT_SKILLS[@]}"; do
        rm -rf "$root/skills/$skill" 2>/dev/null || true
      done
      rm -rf "$root/ba-kit" 2>/dev/null || true
    fi

    echo "Đã gỡ ${label}."
    echo ""
  done

  if $has_claude; then
    clean_hooks_json
  fi

  echo "Để cài lại: npm install -g @bakit-org/cli && ba-kit install"
}

# ============================================================
# RUN
# ============================================================
main "$@"
