    echo "$BACKUP_DIR"
  else
    echo "$(runtime_root_for_key "$key")/ba-kit/backups"
  fi
}

# ============================================================
# PRODUCT REGISTRY HELPERS
# ============================================================
validate_product_registry() {
  local n=${#PRODUCT_IDS[@]}
  test "$n" -eq "${#PRODUCT_IDS[@]}" || { echo "Lỗi: PRODUCT_IDS array has wrong length"; exit 1; }
  test "$n" -eq "${#PRODUCT_NAMES[@]}" || { echo "Lỗi: PRODUCT_NAMES length mismatch"; exit 1; }
  test "$n" -eq "${#PRODUCT_REPOS[@]}" || { echo "Lỗi: PRODUCT_REPOS length mismatch"; exit 1; }
  test "$n" -eq "${#PRODUCT_VISIBILITIES[@]}" || { echo "Lỗi: PRODUCT_VISIBILITIES length mismatch"; exit 1; }
  test "$n" -eq "${#PRODUCT_PROFILES[@]}" || { echo "Lỗi: PRODUCT_PROFILES length mismatch"; exit 1; }
  test "$n" -eq "${#PRODUCT_URLS[@]}" || { echo "Lỗi: PRODUCT_URLS length mismatch"; exit 1; }

  local i=0
  while [ "$i" -lt "$n" ]; do
    local id="${PRODUCT_IDS[$i]}"
    local vis="${PRODUCT_VISIBILITIES[$i]}"
    local prof="${PRODUCT_PROFILES[$i]}"
    local repo="${PRODUCT_REPOS[$i]}"
    [ -n "$id" ] || { echo "Lỗi: empty product id at index $i"; exit 1; }
    [ "$vis" = "public" ] || [ "$vis" = "private" ] || { echo "Lỗi: invalid visibility '$vis' at index $i"; exit 1; }
    [ -n "$prof" ] || { echo "Lỗi: empty profile at index $i"; exit 1; }
    [ -n "$repo" ] || { echo "Lỗi: empty repo at index $i"; exit 1; }
    # Check ID uniqueness
    local j=0
    while [ "$j" -lt "$i" ]; do
      test "${PRODUCT_IDS[$j]}" != "$id" || { echo "Lỗi: duplicate product ID '$id' at indices $j and $i"; exit 1; }
      j=$((j + 1))
    done
    i=$((i + 1))
  done
}

product_index_for_id() {
  local id="$1"
  local i=0
  while [ "$i" -lt "${#PRODUCT_IDS[@]}" ]; do
    if [ "${PRODUCT_IDS[$i]}" = "$id" ]; then
      echo "$i"
      return 0
    fi
    i=$((i + 1))
  done
  return 1
}

product_index_for_name() {
  local name="$1"
  local i=0
  while [ "$i" -lt "${#PRODUCT_NAMES[@]}" ]; do
    if [ "${PRODUCT_NAMES[$i]}" = "$name" ]; then
