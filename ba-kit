# ============================================================
# COMMAND: ba-kit install
# ============================================================
cmd_install() {
  local target_version="latest"
  local target_runtime="claude"

  while [ $# -gt 0 ]; do
    case "$1" in
      --version)
        target_version="$2"
        shift 2
        ;;
      --runtime)
        target_runtime="$2"
        shift 2
        ;;
      *)
        echo "Không hiểu tham số: $1"
        echo "Dùng: ba-kit install [--version v1.2.0] [--runtime claude,codex,agy]"
        exit 1
        ;;
    esac
  done

  parse_runtime_flag "$target_runtime"

  echo ""
  echo "=============================================="
  echo "  BA-KIT INSTALL"
  echo "=============================================="
  echo ""

  check_common_prereqs
  select_product
  select_version "$target_version"

  # Product conflict check per runtime
  local -a RUNTIMES_TO_PROCESS=()
  for key in "${SELECTED_RUNTIME_KEYS[@]}"; do
    if check_cross_product_for_runtime "$key"; then
      RUNTIMES_TO_PROCESS+=("$key")
    fi
  done
  if [ ${#RUNTIMES_TO_PROCESS[@]} -eq 0 ]; then
    echo "Không có runtime nào cần cài/cập nhật."
    exit 0
  fi

  download_release
  extract_release
  install_preflight "${RUNTIMES_TO_PROCESS[@]}"

  echo "Đang cài đặt files..."

  # Keep user-visible backups, then commit every runtime as one transaction.
  for key in "${RUNTIMES_TO_PROCESS[@]}"; do
    local root scope label
    root=$(runtime_root_for_key "$key")
    scope=$(runtime_scope_for_key "$key")
    label=$(runtime_label_for_key "$key")

    echo ""
    echo "-- ${label} (${root}) --"

    # Backup existing state before mutation
    local backup_dir target_root
    while IFS= read -r target_root; do
      backup_dir="${target_root}/ba-kit/backups"
      if [ -d "$target_root" ] && [ "$(ls -A "$target_root" 2>/dev/null)" ]; then
        do_backup "$target_root" "$backup_dir"
      fi
    done < <(runtime_roots_for_key "$key")

  done

  apply_runtime_transaction "${RUNTIMES_TO_PROCESS[@]}"
  post_install_runtimes "${RUNTIMES_TO_PROCESS[@]}"

  cleanup
  show_result "${RUNTIMES_TO_PROCESS[@]}"
}

# ============================================================
# STATE RESOLVER — schema-v3 first, schema-v2/legacy fallback
# ============================================================
# Product aliases: current name + historical aliases
product_alias_of() {
  local id="$1"
  case "$id" in
    ba-kit) echo "BA-kit" ;;
    ba-kit-solo-pro) echo "BA-kit Solo Pro" ;;
    ba-kit-solo-basic) echo "BA-kit Solo Basic" ;;
    *) echo "" ;;
  esac
}

product_id_for_name() {
  local name="$1"
  case "$name" in
    "BA-kit") echo "ba-kit" ;;
    "BA-kit Solo Pro") echo "ba-kit-solo-pro" ;;
    "BA-kit Solo Basic") echo "ba-kit-solo-basic" ;;
    *) echo "" ;;
  esac
}

# Resolve runtime state — canonical schema-v3 first, then schema-v2/legacy
# Sets: STATE_SOURCE, STATE_DATA, STATE_PROFILE, STATE_PRODUCT_ID, STATE_VERSION
resolve_runtime_state() {
  local key="$1"
  local mode="${2:-mutating}"  # mutating | read-only

  STATE_SOURCE=""; STATE_DATA="{}"; STATE_PROFILE=""; STATE_PRODUCT_ID=""; STATE_VERSION=""
  local state_file
  state_file=$(state_file_for_runtime "$key")

  # Canonical schema-v3 state is authoritative and makes the old-CLI barrier
  # safe to ignore for this CLI version.
  if [ -f "$state_file" ]; then
    local st
    st=$(jq -r '.status // "installed"' "$state_file" 2>/dev/null)
    if [ "$st" = "recovery-required" ] && [ "$mode" = "mutating" ]; then
      echo "Lỗi: trạng thái cần khôi phục tại $(runtime_label_for_key "$key"). Chạy ba-kit doctor để xem hướng dẫn." >&2
      STATE_SOURCE="recovery"
      return 1
    fi
    local schema
    schema=$(jq -r '.schema_version // 0' "$state_file" 2>/dev/null)
    if [ "$schema" = "3" ] && ! jq -e --arg runtime "$key" '
      .schema_version == 3 and .runtime_key == $runtime and
      (.payload_schema | type == "number") and
      (.product_id | type == "string") and (.product_id | length > 0) and
      (.product_name | type == "string") and (.profile | type == "string") and
      (.version | type == "string") and (.status | type == "string") and
      (.targets | type == "array") and (.targets | length > 0) and
      (.files | type == "object")
    ' "$state_file" >/dev/null 2>&1; then
      STATE_SOURCE="partial"
      echo "Lỗi: schema-v3 không hợp lệ tại $(runtime_label_for_key "$key"). Chạy ba-kit doctor." >&2
      [ "$mode" = "mutating" ] && return 1
      return 0
    fi
    STATE_SOURCE="$([ "$schema" = "3" ] && echo v3 || echo v2)"
    STATE_DATA=$(cat "$state_file")
    STATE_PRODUCT_ID=$(echo "$STATE_DATA" | jq -r '.product_id // ""')
    STATE_PROFILE=$(echo "$STATE_DATA" | jq -r '.profile // ""')
    STATE_VERSION=$(echo "$STATE_DATA" | jq -r '.version // ""')
    return 0
  fi

  local recovery_marker
  recovery_marker=$(runtime_recovery_marker_for_key "$key")
  if [ -f "$recovery_marker" ]; then
    STATE_SOURCE="recovery"
    STATE_DATA=$(cat "$recovery_marker")
    if [ "$(jq -r '.status // ""' "$recovery_marker" 2>/dev/null)" = "cli-upgrade-required" ]; then
      echo "Lỗi: ${key} cần CLI >= 1.4.0 để tiếp tục." >&2
    elif [ "$mode" = "mutating" ]; then
      echo "Lỗi: trạng thái cần khôi phục tại $(runtime_label_for_key "$key"). Chạy ba-kit doctor để xem hướng dẫn." >&2
      return 1
    fi
    return 0
  fi

  # Legacy detection: VERSION + PRODUCT + release-manifest.json
  local vf pf mf
  vf=$(runtime_version_file "$key")
  pf=$(runtime_product_file "$key")
  mf=$(runtime_manifest_file "$key")

  local has_v=false has_p=false has_m=false
  [ -f "$vf" ] && has_v=true
  [ -f "$pf" ] && has_p=true
  [ -f "$mf" ] && has_m=true

  # No fragments = empty runtime
  if ! $has_v && ! $has_p && ! $has_m; then
    # Check for orphan transaction/recovery fragments
    local rroot
    rroot=$(runtime_root_for_key "$key")
    local tf="${rroot}/ba-kit/transaction.json"
    local rf="${rroot}/ba-kit/RECOVERY_REQUIRED.json"
    if [ -f "$tf" ] || [ -f "$rf" ]; then
      echo "Lỗi: trạng thái BA-kit chưa đầy đủ tại $(runtime_label_for_key "$key"). Không có file nào được thay đổi." >&2
      return 1
    fi
    STATE_SOURCE="empty"
    return 0
  fi

  # Coherent legacy: VERSION + PRODUCT + manifest all present
  if $has_v && $has_p && $has_m; then
    local product_name
    product_name=$(cat "$pf")
    local pid
    pid=$(product_id_for_name "$product_name")
    if [ -z "$pid" ]; then
      echo "Lỗi: sản phẩm '${product_name}' không được hỗ trợ tại $(runtime_label_for_key "$key")." >&2
      STATE_SOURCE="unknown"
      return 1
    fi
    STATE_SOURCE="legacy"
    STATE_PRODUCT_ID="$pid"
    STATE_PROFILE=$(product_index_for_id "$pid" >/dev/null 2>&1 && echo "${PRODUCT_PROFILES[$(product_index_for_id "$pid")]}" || echo "standard")
    STATE_VERSION=$(cat "$vf")
    return 0
  fi

  # Partial/orphan state
  echo "Lỗi: trạng thái BA-kit chưa đầy đủ tại $(runtime_label_for_key "$key"). Không có file nào được thay đổi." >&2
  STATE_SOURCE="partial"
  return 1
}

# === State write helpers ===
commit_canonical_state() {
  local key="$1" next_state_json="$2"
  local state_file
  state_file=$(state_file_for_runtime "$key")
  local dir
  dir=$(dirname "$state_file")
  mkdir -p "$dir"

  echo "$next_state_json" > "${state_file}.tmp"
  mv "${state_file}.tmp" "$state_file"

  # Write compatibility projections
  local vid pid pname ver
  vid=$(echo "$next_state_json" | jq -r '.product_id // ""')
  pid=$(echo "$next_state_json" | jq -r '.product_name // ""')
  ver=$(echo "$next_state_json" | jq -r '.version // ""')
  echo "$ver" > "$(runtime_version_file "$key")"
  echo "$pid" > "$(runtime_product_file "$key")"
  echo "$vid" > "${dir}/PRODUCT_ID"
}

# ============================================================
# COMMAND: ba-kit update
# ============================================================
cmd_update() {
  echo ""
  echo "=============================================="
  echo "  BA-KIT UPDATE"
  echo "=============================================="
  echo ""

  check_common_prereqs

  # Auto-detect runtimes with canonical or legacy state
  local -a DETECTED_KEYS=()
  for key in "${RUNTIME_KEYS[@]}"; do
    resolve_runtime_state "$key" "read-only" || true
    if [ "${STATE_SOURCE:-empty}" != "empty" ]; then
      DETECTED_KEYS+=("$key")
    fi
  done

  if [ ${#DETECTED_KEYS[@]} -eq 0 ]; then
    echo "BA-kit chưa được cài đặt."
    echo "Chạy: ba-kit install"
    exit 1
  fi

  # Group by product-id from resolved state
  local -a GROUP_IDS=() GROUP_KEYS=()
  for key in "${DETECTED_KEYS[@]}"; do
    resolve_runtime_state "$key" "mutating" || true
    local idx=-1
    for i in "${!GROUP_IDS[@]}"; do
      if [ "${GROUP_IDS[$i]}" = "$STATE_PRODUCT_ID" ]; then
        idx=$i; break
      fi
    done
    if [ "$idx" -eq -1 ]; then
      GROUP_IDS+=("$STATE_PRODUCT_ID")
      GROUP_KEYS+=("$key")
    else
      GROUP_KEYS[$idx]="${GROUP_KEYS[$idx]},${key}"
    fi
  done

  if [ ${#GROUP_IDS[@]} -gt 1 ]; then
    echo "Đang cập nhật ${#GROUP_IDS[@]} nhóm sản phẩm..."
    echo ""
  fi

  local -a ALL_PROCESSED=()
  for gi in "${!GROUP_IDS[@]}"; do
    local gid="${GROUP_IDS[$gi]}"
    local alias
    alias=$(product_alias_of "$gid")
    local -a gkeys
    IFS=',' read -r -a gkeys <<< "${GROUP_KEYS[$gi]}"

    echo "Sản phẩm: ${alias} (${gid})"
    for key in "${gkeys[@]}"; do
      local label
      label=$(runtime_label_for_key "$key")
      resolve_runtime_state "$key" "read-only" || true
      echo "  ${label}: ${STATE_VERSION:-unknown}"
    done

    local repo="" purl="" vis="" prof="" idx
    idx=$(product_index_for_id "$gid" 2>/dev/null) || {
      echo "Lỗi: Sản phẩm '$gid' không được hỗ trợ."
      exit 1
    }
    repo="${PRODUCT_REPOS[$idx]}"
    purl="${PRODUCT_URLS[$idx]}"
    vis="${PRODUCT_VISIBILITIES[$idx]}"
    prof="${PRODUCT_PROFILES[$idx]}"

    # Verify access for private products
    if [ "$vis" = "private" ]; then
      require_private_github_access "$alias"
      if ! gh api "repos/${repo}" --jq '.private' &>/dev/null 2>&1; then
        echo "Quyền truy cập ${alias} đã bị thu hồi."
        exit 1
      fi
    fi

    local latest
    latest=$(get_release_json "latest" | jq -r '.tag_name') || {
      echo "Lỗi: Không thể kiểm tra phiên bản mới."
      exit 1
    }
    echo "Phiên bản mới nhất: ${latest}"

    local all_latest=true
    for key in "${gkeys[@]}"; do
      resolve_runtime_state "$key" "read-only" || true
      if [ "${STATE_VERSION#v}" != "${latest#v}" ]; then
        all_latest=false; break
      fi
    done
    if $all_latest && node "$RUNTIME_LIFECYCLE_HELPER" doctor --home "$HOME" --runtimes "$(IFS=,; echo "${gkeys[*]}")" >/dev/null 2>&1; then
      echo "Đang dùng phiên bản mới nhất."
      echo ""
      continue
    fi

    read -r -p "Cập nhật lên ${latest}? (Y/n): " confirm
    if [ "$(lowercase "$confirm")" = "n" ]; then
      echo "Đã hủy nhóm ${alias}."
      echo ""
      continue
    fi

    # Set globals and run install path
    select_product_index "$idx"
    SELECTED_VERSION="$latest"
    SELECTED_RUNTIME_KEYS=("${gkeys[@]}")
    download_release
    extract_release
    install_preflight "${gkeys[@]}"

    echo "Đang cập nhật files..."
    for key in "${gkeys[@]}"; do
      local root label
      root=$(runtime_root_for_key "$key")
      label=$(runtime_label_for_key "$key")
      echo ""
      echo "-- ${label} (${root}) --"
      local backup_dir target_root
      while IFS= read -r target_root; do
        backup_dir="${target_root}/ba-kit/backups"
        [ -d "$target_root" ] && [ "$(ls -A "$target_root" 2>/dev/null)" ] && do_backup "$target_root" "$backup_dir"
      done < <(runtime_roots_for_key "$key")
    done
    apply_runtime_transaction "${gkeys[@]}"
    post_install_runtimes "${gkeys[@]}"
    ALL_PROCESSED+=("${gkeys[@]}")
    cleanup
    echo ""
  done

  if [ ${#ALL_PROCESSED[@]} -gt 0 ]; then
    show_result "${ALL_PROCESSED[@]}"
  fi
}

# ============================================================
# COMMAND: ba-kit doctor
# ============================================================
cmd_doctor() {
  echo ""

  local runtime_doctor_status=0
  if [ -f "$RUNTIME_LIFECYCLE_HELPER" ]; then
    node "$RUNTIME_LIFECYCLE_HELPER" doctor --home "$HOME" --runtimes "claude,codex,agy" || runtime_doctor_status=$?
  fi
  echo "=============================================="
  echo "  BA-kit HEALTH CHECK"
  echo "=============================================="
  echo ""

  local any_installed=false
  for key in "${RUNTIME_KEYS[@]}"; do
    local label
    label=$(runtime_label_for_key "$key")
    resolve_runtime_state "$key" "read-only" || true

    case "${STATE_SOURCE:-empty}" in
      v3|v2)
        local st
        st=$(echo "$STATE_DATA" | jq -r '.status')
        local alias
        alias=$(product_alias_of "$STATE_PRODUCT_ID")
        echo "[OK]   ${label}: ${alias} ${STATE_VERSION} (schema-${STATE_SOURCE#v}, ${st})"
        any_installed=true
        ;;
      legacy)
        local alias
        alias=$(product_alias_of "$STATE_PRODUCT_ID")
        echo "[OK]   ${label}: ${alias} ${STATE_VERSION} (legacy)"
        any_installed=true
        ;;
      recovery)
        echo "[CẦN KHÔI PHỤC] ${label}: giao dịch trước đó chưa được khôi phục hoàn toàn"
        any_installed=true
        ;;
      empty)
        echo "[CHƯA] ${label}: chưa cài đặt"
        ;;
    esac
  done

  if ! $any_installed; then
    echo "       Chạy: ba-kit install"
  fi

  # jq and curl (always needed)
  echo "[OK]   jq: $(jq --version 2>/dev/null || echo 'missing')"
  echo "[OK]   curl: $(curl --version 2>/dev/null | head -1 || echo 'missing')"

  # gh: only needed for private products
  if github_auth_available; then
    echo "[OK]   GitHub CLI: đã đăng nhập (cho sản phẩm riêng tư)"
  else
    echo "[OK]   GitHub CLI: chưa đăng nhập (Solo Basic vẫn dùng được)"
  fi

  echo ""
  echo "Quyền truy cập:"
  for i in "${!PRODUCT_IDS[@]}"; do
    local vid="${PRODUCT_IDS[$i]}"
    local vname="${PRODUCT_NAMES[$i]}"
    local vis="${PRODUCT_VISIBILITIES[$i]}"
    if [ "$vis" = "public" ]; then
      echo "  [OK]   ${vname} — miễn phí, luôn có sẵn"
    elif github_auth_available; then
      local repo="${PRODUCT_REPOS[$i]}"
      if gh api "repos/${repo}" --jq '.private' &>/dev/null 2>&1; then
        echo "  [OK]   ${vname} — có quyền truy cập"
      else
        echo "  [THIẾU] ${vname} — chưa có quyền"
      fi
    else
      echo "  [THIẾU] ${vname} — cần gh auth login"
    fi
  done

  # Components for installed runtimes
  echo ""
  echo "Components đã cài:"
  for key in "${RUNTIME_KEYS[@]}"; do
    resolve_runtime_state "$key" "read-only" || true
    [ "${STATE_SOURCE:-empty}" = "empty" ] && continue

    local root label
    root=$(runtime_root_for_key "$key")
    label=$(runtime_label_for_key "$key")

    echo "  ${label}:"
    if [ "$STATE_SOURCE" = "v3" ] || [ "$STATE_SOURCE" = "v2" ]; then
      local scount tcount
      scount=$(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ')
      tcount=$(ls -1 "$root/templates/" 2>/dev/null | wc -l | tr -d ' ')
      echo "    Skills:    ${scount}"
      echo "    Templates: ${tcount}"

      if [ "$STATE_PROFILE" = "solo-basic" ]; then
        if [ -d "$root/core" ]; then echo "    Core:      ${root}/core/"; fi
        echo "    Không có agents, hooks, scripts."
      elif [ "$STATE_PROFILE" = "standard" ]; then
        [ -d "$root/agents" ] && echo "    Agents:    $(ls -1 "$root/agents/" 2>/dev/null | wc -l | tr -d ' ') file"
        [ -d "$root/hooks" ] && echo "    Hooks:     $(ls -1 "$root/hooks/" 2>/dev/null | wc -l | tr -d ' ') file"
        [ -d "$root/ba-kit" ] && echo "    Core:      ${root}/ba-kit/"
        if command -v python3 &>/dev/null; then
          echo "    Python:    $(python3 --version 2>&1)"
        fi
      fi
    else
      [ -d "$root/skills" ] && echo "    Skills: $(ls -1 "$root/skills/" 2>/dev/null | wc -l | tr -d ' ') thư mục (legacy)"
    fi
  done

  echo ""
  return "$runtime_doctor_status"
}

# ============================================================
# COMMAND: ba-kit version
# ============================================================
cmd_version() {
  echo "BA-kit CLI: v${CLI_VERSION}"
  for key in "${RUNTIME_KEYS[@]}"; do
    local label
    label=$(runtime_label_for_key "$key")
    resolve_runtime_state "$key" "read-only" || true
    case "${STATE_SOURCE:-empty}" in
      v3|v2)
        local alias
        alias=$(product_alias_of "$STATE_PRODUCT_ID")
        echo "  ${label}: ${alias} v${STATE_VERSION}"
        ;;
      legacy)
        local alias
        alias=$(product_alias_of "$STATE_PRODUCT_ID")
        echo "  ${label}: ${alias} ${STATE_VERSION} (legacy)"
        ;;
      empty)
        echo "  ${label}: (chưa cài)"
        ;;
    esac
  done
}

# ============================================================
# COMMAND: ba-kit uninstall
# ============================================================
cmd_uninstall() {
  local target_runtime=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --runtime)
        target_runtime="$2"
        shift 2
        ;;
      *)
        echo "Không hiểu tham số: $1"
        echo "Dùng: ba-kit uninstall [--runtime claude,codex,agy]"
        exit 1
        ;;
    esac
  done

  local -a TARGET_RUNTIME_KEYS=()
  if [ -n "$target_runtime" ]; then
    parse_runtime_flag "$target_runtime"
    TARGET_RUNTIME_KEYS=("${SELECTED_RUNTIME_KEYS[@]}")
  else
    for key in "${RUNTIME_KEYS[@]}"; do
      resolve_runtime_state "$key" "read-only" || true
      if [ "${STATE_SOURCE:-empty}" != "empty" ]; then
        TARGET_RUNTIME_KEYS+=("$key")
      fi
    done
  fi

  if [ ${#TARGET_RUNTIME_KEYS[@]} -eq 0 ]; then
    echo "Không có runtime nào đã cài."
    exit 0
  fi

  echo ""
  echo "=============================================="
  echo "  GỠ CÀI ĐẶT"
  echo "=============================================="
  echo ""
  echo "Sẽ gỡ các runtime sau (có backup trước khi xóa):"
  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    local label root
    label=$(runtime_label_for_key "$key")
    root=$(runtime_root_for_key "$key")
    resolve_runtime_state "$key" "read-only" || true
    local alias
    alias=$(product_alias_of "${STATE_PRODUCT_ID:-}")
    echo "  - ${label} (${root}): ${alias:-unknown} ${STATE_VERSION:-unknown}"
  done
  echo ""

  read -r -p "Bạn có chắc muốn tiếp tục? (y/N): " confirm
  if [ "$(lowercase "$confirm")" != "y" ]; then
    echo "Đã hủy."
    exit 0
  fi

  echo ""

  if [ -f "$RUNTIME_LIFECYCLE_HELPER" ]; then
    node "$RUNTIME_LIFECYCLE_HELPER" uninstall --home "$HOME" --runtimes "$(IFS=,; echo "${TARGET_RUNTIME_KEYS[*]}")"
    echo "Đã gỡ các runtime được chọn bằng transaction schema-v3."
    exit 0
  fi

  local has_claude=false
  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    [ "$key" = "claude" ] && has_claude=true
  done

  for key in "${TARGET_RUNTIME_KEYS[@]}"; do
    local root label
    root=$(runtime_root_for_key "$key")
    label=$(runtime_label_for_key "$key")
    local backup_dir backup_path
    backup_dir=$(runtime_backup_dir "$key")
    backup_path="${backup_dir}/pre-uninstall-$(date +%Y-%m-%d-%H%M%S)"

    resolve_runtime_state "$key" "mutating" || { echo "Lỗi: không thể đọc trạng thái ${label}."; exit 1; }
    echo "-- ${label} (${root}) --"

    # Backup state + owned files
    mkdir -p "$backup_path"
      if [ "${STATE_SOURCE:-}" = "v3" ] || [ "${STATE_SOURCE:-}" = "v2" ]; then
      local state_file mf
      state_file=$(state_file_for_runtime "$key")
      [ -f "$state_file" ] && cp "$state_file" "$backup_path/state.json"
      mf=$(runtime_manifest_file "$key")
      [ -f "$mf" ] && cp "$mf" "$backup_path/release-manifest.json"

      # Delete only unchanged managed files
      local kept=0 deleted=0
      local file_keys
      file_keys=$(echo "$STATE_DATA" | jq -r '.files | keys[]' 2>/dev/null)
      while IFS= read -r fk; do
        [ -z "$fk" ] && continue
        local fstatus vendor_hash dest
        fstatus=$(echo "$STATE_DATA" | jq -r ".files[\"$fk\"].status // \"managed\"")
        vendor_hash=$(echo "$STATE_DATA" | jq -r ".files[\"$fk\"].source_sha256 // empty")

        # Map manifest key to runtime path
        dest=$(manifest_key_to_runtime_path "$STATE_PROFILE" "$key" "$fk" 2>/dev/null) || continue
        [ -z "$dest" ] && continue
        local full_path="${root}/${dest}"

        if [ "$fstatus" = "managed" ] && [ -f "$full_path" ]; then
          local curr_hash
          curr_hash=$(sha256 "$full_path")
          if [ "$curr_hash" = "$vendor_hash" ] || [ "$vendor_hash" = "null" ]; then
            rm -f "$full_path"
            deleted=$((deleted + 1))
          else
            kept=$((kept + 1))
          fi
        elif [ "$fstatus" = "preserved-modified" ] || [ "$fstatus" = "preserved-retired" ]; then
          kept=$((kept + 1))
        elif [ "$fstatus" = "unknown-preserved" ]; then
          kept=$((kept + 1))
        elif [ -f "$full_path" ]; then
          # unclassified owned files — preserve
          kept=$((kept + 1))
        fi
      done <<< "$file_keys"

      echo "  ${deleted} file đã xóa | ${kept} file giữ nguyên"

      # If any files preserved, write tombstone
      if [ "$kept" -gt 0 ]; then
        local tombstone
        tombstone=$(echo "$STATE_DATA" | jq \
          --arg status "uninstalled-with-preserved-files" \
          '.status = $status')
        commit_canonical_state "$key" "$tombstone"
        echo "  Giữ nguyên ${kept} file đã chỉnh sửa; trạng thái bảo vệ được lưu để cài lại an toàn."
      else
        # Fully remove state
        local dir
        dir=$(dirname "$(state_file_for_runtime "$key")")
        rm -f "$(state_file_for_runtime "$key")"
        rm -f "$(runtime_version_file "$key")"
        rm -f "$(runtime_product_file "$key")"
        rm -f "$(runtime_manifest_file "$key")"
        rm -f "${dir}/PRODUCT_ID" "${dir}/VERSION" "${dir}/PRODUCT" 2>/dev/null || true
      fi
    else
      # Legacy uninstall: backup and remove known paths
      if [ -d "$root/skills" ]; then
        for skill in "${BA_KIT_SKILLS[@]}"; do
          rm -rf "$root/skills/$skill" 2>/dev/null || true
        done
      fi
      rm -rf "$root/ba-kit" 2>/dev/null || true
      rm -f "$root/core" 2>/dev/null || true
      echo "  Đã gỡ (legacy)."
    fi

    echo "Đã gỡ ${label}."
    echo ""
  done

  if $has_claude && [ -d "$HOME/.claude" ]; then
    clean_hooks_json
  fi

  echo "Để cài lại: npm install -g @bakit-org/cli && ba-kit install"
}

