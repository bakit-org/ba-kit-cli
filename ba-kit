# Emits rows: source_relative | dest_relative | manifest_key_prefix
profile_components() {
  local profile="$1" runtime_key="$2"

  case "${profile}:${runtime_key}" in
    standard:claude)
      echo ".claude|.|./.claude/"
      echo "ba-kit|ba-kit|./ba-kit/"
      ;;
    standard:codex)
      echo ".codex/skills|skills|./.codex/skills/"
      echo ".codex/agents|agents|./.codex/agents/"
      echo ".codex/templates|templates|./.codex/templates/"
      echo ".codex/ba-kit|ba-kit|./.codex/ba-kit/"
      ;;
    standard:agy)
      echo ".antigravity/skills|skills|./.antigravity/skills/"
      echo ".antigravity/templates|ba-kit/templates|./.antigravity/templates/"
      echo ".antigravity/core|ba-kit/core|./.antigravity/core/"
      echo ".antigravity/guardrails|ba-kit/scripts|./.antigravity/guardrails/"
      echo ".antigravity/knowledge/ba-kit-workflow|knowledge/ba-kit-workflow|./.antigravity/knowledge/ba-kit-workflow/"
      ;;
    solo-basic:*)
      echo ".claude/skills|skills|./.claude/skills/"
      echo ".claude/templates|templates|./.claude/templates/"
      echo "ba-kit/core|core|./ba-kit/core/"
      ;;
    *)
      echo "Unknown profile/runtime: ${profile}/${runtime_key}" >&2
      return 1
      ;;
  esac
}

# Map an archive manifest key to runtime-relative destination path
manifest_key_to_runtime_path() {
  local profile="$1" runtime_key="$2" key="$3"

  # Resolve which component owns this key
  while IFS='|' read -r src_rel dest_rel prefix; do
    [ -z "$prefix" ] && continue
    # Check if key starts with prefix
    case "$key" in
      "${prefix}"*)
        local rel="${key#"$prefix"}"
        echo "${dest_rel}/${rel}"
        return 0
        ;;
    esac
  done < <(profile_components "$profile" "$runtime_key")

  return 1  # key not owned by this profile/runtime
}

# Validate Solo-specific archive payload structure
validate_solo_release_payload() {
  local extract_dir="$1"

  # Top-level roots: .claude, ba-kit, manifest.json, release-manifest.json
  local expected_roots=".claude ba-kit manifest.json release-manifest.json"
  local actual_roots
  actual_roots=$(cd "$extract_dir" && ls -A | sort | paste -sd ' ' -)
  if [ "$actual_roots" != "$expected_roots" ]; then
    echo "Lỗi: Cấu trúc archive Solo không đúng. Mong đợi: ${expected_roots}, thực tế: ${actual_roots}"
    exit 1
  fi

  # .claude children: skills + templates only
  local claude_children
  claude_children=$(cd "$extract_dir/.claude" && ls -A | sort | paste -sd ' ' - 2>/dev/null)
  if [ "$claude_children" != "skills templates" ]; then
    echo "Lỗi: .claude/ trong archive Solo phải chỉ có skills/ và templates/"
    exit 1
  fi

  # ba-kit child: core only
  local bakit_children
  bakit_children=$(cd "$extract_dir/ba-kit" && ls -A | sort | paste -sd ' ' - 2>/dev/null)
  if [ "$bakit_children" != "core" ]; then
    echo "Lỗi: ba-kit/ trong archive Solo phải chỉ có core/"
    exit 1
  fi

  # Exactly 5 skills
  local expected_skills="ba-do ba-impact ba-next ba-start brainstorm"
  local actual_skills
  actual_skills=$(cd "$extract_dir/.claude/skills" && ls -d */ 2>/dev/null | sed 's|/||g' | sort | paste -sd ' ' -)
  if [ "$actual_skills" != "$expected_skills" ]; then
    echo "Lỗi: Skill set không đúng. Mong đợi: ${expected_skills}, thực tế: ${actual_skills}"
    exit 1
  fi
}

