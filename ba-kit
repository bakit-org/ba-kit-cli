    echo "  Windows:          winget install GitHub.CLI"
    echo "                     Hoặc tải từ: https://cli.github.com"
    echo "  Linux (Ubuntu):   sudo apt install gh"
    echo "  Linux (Fedora):   sudo dnf install gh"
