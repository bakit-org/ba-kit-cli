  echo "  2. Bạn đã mua nhưng chưa accept GitHub invite"
  echo ""
  echo "Cách khắc phục:"
  echo "  - Chưa mua:  vào https://polar.sh/checkout/polar_c_Bd8xfL8VTBQtYpol2MdbS2M5acEFMsjKmDFec0bYVGF để mua"
