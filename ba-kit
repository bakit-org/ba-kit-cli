# === INSTALL-SPECIFIC: Preflight mutation across all selected runtimes ===
install_preflight() {
  local key
  for key in "$@"; do
    local root pfile existing
    while IFS= read -r root; do
      pfile="${root}/ba-kit/PRODUCT"
      if [ -f "$pfile" ]; then
        existing=$(cat "$pfile")
        if [ "$existing" != "$SELECTED_PRODUCT" ]; then
          echo "Lỗi: ${SELECTED_PRODUCT} không thể cài đè lên ${existing}."
          echo "Gỡ ${existing} trước: ba-kit uninstall --runtime ${key}"
          exit 1
        fi
      fi
    done < <(runtime_roots_for_key "$key")

    # Schema-v3 compatibility barriers are validated by the lifecycle helper
    # for every detected target. Do not reject a valid v3 install here.
  done

  if [ "$SELECTED_PROFILE" = "solo-basic" ]; then
    validate_solo_release_payload "$EXTRACT_DIR"
  fi
}

runtime_recovery_marker_for_key() {
  echo "$(runtime_root_for_key "$1")/ba-kit/RECOVERY_REQUIRED.json"
}

# Emit only files this install may change. Never snapshot whole runtime roots:
# they contain user-owned settings, skills, caches, and unrelated integrations.
transaction_runtime_paths() {
  local key="$1" manifest_key runtime_path
  while IFS= read -r manifest_key; do
    runtime_path=$(manifest_key_to_runtime_path "$SELECTED_PROFILE" "$key" "$manifest_key" 2>/dev/null) || continue
    [ -n "$runtime_path" ] && printf '%s\n' "$runtime_path"
  done < <(jq -r 'keys[]' "$EXTRACT_DIR/release-manifest.json")
  printf '%s\n' \
    "ba-kit/state.json" \
    "ba-kit/VERSION" \
    "ba-kit/PRODUCT" \
    "ba-kit/PRODUCT_ID" \
    "ba-kit/release-manifest.json" \
    "ba-kit/RECOVERY_REQUIRED.json" \
    | sort -u
}

snapshot_transaction_runtime() {
  local transaction_dir="$1" key="$2" root rel source snapshot record
  root=$(runtime_root_for_key "$key")
  snapshot="${transaction_dir}/${key}"
  record="${snapshot}/records.tsv"
  mkdir -p "${snapshot}/files"
  : > "$record"

  while IFS= read -r rel; do
    [ -z "$rel" ] && continue
    source="${root}/${rel}"
    if [ -L "$source" ]; then
      printf 'symlink\t%s\t%s\n' "$rel" "$(readlink "$source")" >> "$record"
    elif [ -f "$source" ]; then
      mkdir -p "$(dirname "${snapshot}/files/${rel}")"
      cp -p "$source" "${snapshot}/files/${rel}"
      printf 'file\t%s\t\n' "$rel" >> "$record"
    else
      printf 'absent\t%s\t\n' "$rel" >> "$record"
    fi
  done < <(transaction_runtime_paths "$key")
}

restore_transaction_runtime() {
  local transaction_dir="$1" key="$2" root snapshot kind rel target destination failed=0
  root=$(runtime_root_for_key "$key")
  snapshot="${transaction_dir}/${key}"
  while IFS=$'\t' read -r kind rel target; do
    [ -z "$rel" ] && continue
    destination="${root}/${rel}"
    case "$kind" in
      file)
        mkdir -p "$(dirname "$destination")" || failed=1
        cp -p "${snapshot}/files/${rel}" "$destination" || failed=1
        ;;
      symlink)
        mkdir -p "$(dirname "$destination")" || failed=1
        rm -f "$destination" || failed=1
        ln -s "$target" "$destination" || failed=1
        ;;
      absent)
        rm -f "$destination" || failed=1
        ;;
    esac
  done < "${snapshot}/records.tsv"
  return "$failed"
}

rollback_install_transaction() {
  local transaction_dir="$1" index key failed=0
  index=$((${#TRANSACTION_KEYS[@]} - 1))
  while [ "$index" -ge 0 ]; do
    key="${TRANSACTION_KEYS[$index]}"
    restore_transaction_runtime "$transaction_dir" "$key" || {
      failed=1
      mkdir -p "$(dirname "$(runtime_recovery_marker_for_key "$key")")"
      printf '{"status":"recovery-required","operation":"install"}\n' \
        > "$(runtime_recovery_marker_for_key "$key")"
    }
    index=$((index - 1))
  done
  return "$failed"
}

transaction_failed() {
  local status="$1"
  trap - ERR INT TERM
  echo "Lỗi: cài đặt thất bại, đang khôi phục các runtime đã thay đổi..." >&2
  rollback_install_transaction "$TRANSACTION_DIR" || \
    echo "Lỗi: một runtime cần khôi phục thủ công; chạy ba-kit doctor." >&2
  rm -rf "$TRANSACTION_DIR"
  exit "$status"
}

apply_runtime_transaction() {
  local runtime_list
  runtime_list=$(IFS=,; echo "$*")
  node "$RUNTIME_LIFECYCLE_HELPER" install \
    --extract "$EXTRACT_DIR" \
    --runtimes "$runtime_list" \
    --profile "$SELECTED_PROFILE" \
    --product_id "$SELECTED_PRODUCT_ID" \
    --product_name "$SELECTED_PRODUCT" \
    --version "${SELECTED_VERSION#v}"
}

# === INSTALL-SPECIFIC: Apply payload for one runtime ===
install_runtime_payload() {
  local key="$1"
  local root scope label
  root=$(runtime_root_for_key "$key")
  scope=$(runtime_scope_for_key "$key")
  label=$(runtime_label_for_key "$key")

  local state_dir="${root}/ba-kit"
  mkdir -p "$state_dir"

  # Build schema-v2 state
  local generation=1
  local state_json
  state_json=$(jq -n \
    --arg schema "2" \
    --arg gen "$generation" \
    --arg pid "$SELECTED_PRODUCT_ID" \
    --arg pname "$SELECTED_PRODUCT" \
    --arg prof "$SELECTED_PROFILE" \
    --arg ver "${SELECTED_VERSION#v}" \
    --arg status "installed" \
    '{schema_version: ($schema|tonumber), generation: ($gen|tonumber), product_id: $pid, product_name: $pname, profile: $prof, version: $ver, status: $status, files: {}}')

  local created=0 updated=0 preserved=0
  local old_manifest="{}"
  [ -f "$(runtime_manifest_file "$key")" ] && old_manifest=$(cat "$(runtime_manifest_file "$key")")

  # Read release manifest for this install
  local release_manifest
  release_manifest=$(cat "$EXTRACT_DIR/release-manifest.json")

  # Process each component from profile
  while IFS='|' read -r src_rel dest_rel prefix; do
    [ -z "$prefix" ] && continue
    local src_dir="$EXTRACT_DIR/$src_rel"

    [ ! -d "$src_dir" ] && continue

    # For each file in release manifest matching this component prefix
    local keys
    keys=$(echo "$release_manifest" | jq -r "keys[] | select(startswith(\"${prefix}\"))" 2>/dev/null)

    while IFS= read -r manifest_key; do
      [ -z "$manifest_key" ] && continue
      local rel_path="${manifest_key#"$prefix"}"
      local dest_path="${root}/${dest_rel}/${rel_path}"
      mkdir -p "$(dirname "$dest_path")"

      local new_hash
      new_hash=$(echo "$release_manifest" | jq -r ".\"$manifest_key\"")

      if [ ! -f "$dest_path" ]; then
        # New file
        cp "$src_dir/$rel_path" "$dest_path"
        created=$((created + 1))
        state_json=$(echo "$state_json" | jq --arg k "$manifest_key" --arg h "$new_hash" \
          '.files[$k] = {"source_sha256": $h, "status": "managed"}')
      else
        local current_hash old_hash
        current_hash=$(sha256 "$dest_path")
        old_hash=$(echo "$old_manifest" | jq -r ".\"$manifest_key\" // empty" 2>/dev/null)

        if [ "$current_hash" = "$new_hash" ]; then
          updated=$((updated + 1))
          state_json=$(echo "$state_json" | jq --arg k "$manifest_key" --arg h "$new_hash" \
            '.files[$k] = {"source_sha256": $h, "status": "managed"}')
        elif [ -n "$old_hash" ] && [ "$current_hash" = "$old_hash" ]; then
          cp "$src_dir/$rel_path" "$dest_path"
          updated=$((updated + 1))
          state_json=$(echo "$state_json" | jq --arg k "$manifest_key" --arg h "$new_hash" \
            '.files[$k] = {"source_sha256": $h, "status": "managed"}')
        elif [ -n "$old_hash" ]; then
          preserved=$((preserved + 1))
          state_json=$(echo "$state_json" | jq --arg k "$manifest_key" --arg h "$old_hash" \
            '.files[$k] = {"source_sha256": $h, "status": "preserved-modified"}')
        elif is_protected "$rel_path"; then
          preserved=$((preserved + 1))
        else
          # Unmodified, adopt
          cp "$src_dir/$rel_path" "$dest_path"
          updated=$((updated + 1))
          state_json=$(echo "$state_json" | jq --arg k "$manifest_key" --arg h "$new_hash" \
            '.files[$k] = {"source_sha256": $h, "status": "managed"}')
        fi
      fi
    done <<< "$keys"
  done < <(profile_components "$SELECTED_PROFILE" "$key")

  echo "  ${created} file mới | ${updated} file cập nhật | ${preserved} file giữ nguyên"

  # Increment generation and write
  generation=$((generation + 1))
  state_json=$(echo "$state_json" | jq --arg g "$generation" '.generation = ($g | tonumber)')
  write_state_v2 "$key" "$state_json"

  # Write compatibility projections
  mkdir -p "$state_dir"
  echo "$SELECTED_VERSION" > "$(runtime_version_file "$key")"
  echo "$SELECTED_PRODUCT" > "$(runtime_product_file "$key")"
  echo "${SELECTED_PRODUCT_ID:-}" > "${state_dir}/PRODUCT_ID"
  cp "$EXTRACT_DIR/release-manifest.json" "$(runtime_manifest_file "$key")"

}

