runtime_index_for_key() {   # $1=key -> echoes index or returns 1
  local key="$1"
  for i in "${!RUNTIME_KEYS[@]}"; do
    if [ "${RUNTIME_KEYS[$i]}" = "$key" ]; then
      echo "$i"
      return 0
    fi
  done
  return 1
}

runtime_root_for_key()  {
  if [ "$1" = "agy" ]; then
    for candidate in "$HOME/.gemini/antigravity" "$HOME/.gemini/antigravity-cli" "$HOME/.gemini/antigravity-ide"; do
      [ -d "$candidate" ] && { echo "$candidate"; return; }
    done
  fi
  local i; i=$(runtime_index_for_key "$1") && echo "${RUNTIME_ROOTS[$i]}"
}
runtime_roots_for_key() {
  if [ "$1" != "agy" ]; then runtime_root_for_key "$1"; return; fi
  local found=false candidate
  for candidate in "$HOME/.gemini/antigravity" "$HOME/.gemini/antigravity-cli" "$HOME/.gemini/antigravity-ide"; do
    if [ -d "$candidate" ]; then echo "$candidate"; found=true; fi
  done
  $found || echo "$HOME/.gemini/antigravity"
}
runtime_label_for_key() { local i; i=$(runtime_index_for_key "$1") && echo "${RUNTIME_LABELS[$i]}"; }
runtime_scope_for_key() { local i; i=$(runtime_index_for_key "$1") && echo "${RUNTIME_SCOPES[$i]}"; }

runtime_version_file()  { echo "$(runtime_root_for_key "$1")/ba-kit/VERSION"; }
runtime_product_file()  { echo "$(runtime_root_for_key "$1")/ba-kit/PRODUCT"; }
runtime_manifest_file() { echo "$(runtime_root_for_key "$1")/ba-kit/release-manifest.json"; }
runtime_backup_dir() {
