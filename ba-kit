# === ENTRY POINT ===
# ponytail: portable lowercase — macOS bash 3.2 doesn't support ${var,,}
lowercase() { echo "$1" | tr '[:upper:]' '[:lower:]'; }

# ponytail: portable sha256 — stock macOS has no sha256sum, only shasum -a 256
sha256() {
  if command -v sha256sum &>/dev/null; then
    sha256sum "$1" | cut -d' ' -f1
  else
    shasum -a 256 "$1" | cut -d' ' -f1
  fi
}
main() {
  case "${1:-}" in
    install)   shift; cmd_install "$@" ;;
    update)    cmd_update ;;
    doctor)    cmd_doctor ;;
    version)   cmd_version ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    help|--help|-h)
      usage
      ;;
    *)
      # Forward to framework ba-kit for all BA operations
      local framework_bin=""
      for candidate in "$HOME/.claude/ba-kit/ba-kit" "$HOME/.local/bin/ba-kit" "$HOME/.claude/ba-kit/scripts/ba-kit"; do
        if [ -x "$candidate" ] && [ "$(realpath "$candidate" 2>/dev/null || echo "$candidate")" != "$(realpath "$0" 2>/dev/null || echo "$0")" ]; then
          framework_bin="$candidate"
          break
        fi
      done
      if [ -n "$framework_bin" ]; then
        exec "$framework_bin" "$@"
      fi
      echo "BA-kit CLI — chưa cài framework. Chạy: ba-kit install"
      echo ""
      echo "Commands:"
      echo "  ba-kit install                     Cài đặt BA-kit lần đầu"
      echo "  ba-kit install --version X         Cài version cụ thể (vd: v1.2.0)"
      echo "  ba-kit install --runtime <list>    Chọn runtime: claude,codex,agy (mặc định: claude)"
      echo "  ba-kit update                      Cập nhật lên phiên bản mới nhất (mọi runtime đã cài)"
      echo "  ba-kit doctor                      Kiểm tra trạng thái cài đặt"
      echo "  ba-kit version                     Hiển thị phiên bản CLI + từng runtime đã cài"
      echo "  ba-kit uninstall                   Gỡ cài đặt (có backup)"
      echo "  ba-kit uninstall --runtime <list>  Chỉ gỡ runtime chỉ định (mặc định: tự phát hiện tất cả)"
      echo ""
      echo "Runtime hỗ trợ:"
      echo "  claude  Claude Code — đầy đủ (skills, agents, hooks, templates)"
      echo "  codex   Codex CLI — chỉ skills"
      echo "  agy     Antigravity IDE — chỉ skills"
      echo ""
      echo "Các sản phẩm:"
      for i in "${!PRODUCT_NAMES[@]}"; do
        echo "  ${PRODUCT_NAMES[$i]} — ${PRODUCT_URLS[$i]}"
      done
      ;;
  esac
}

usage() {
  echo "BA-kit CLI"
  echo ""
  echo "Commands:"
  echo "  ba-kit install                     Cài đặt BA-kit lần đầu"
  echo "  ba-kit install --version X         Cài version cụ thể"
