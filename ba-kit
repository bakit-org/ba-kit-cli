# ============================================================
# Auto-install helpers — detect OS/package manager, offer to install
# missing CLI deps instead of just printing instructions and exiting.
# Always confirms before running anything (no silent sudo/system changes).
# ============================================================

# winget-installed portable packages (jq, etc.) get a shim in
# %LOCALAPPDATA%\Microsoft\WinGet\Links, added to the User PATH via a
# registry broadcast — but that broadcast never reaches an
# already-running bash session. Without this, a tool winget installed in
# an earlier session reads as "missing" here, triggering a pointless
# reinstall attempt that winget correctly refuses ("already installed,
# no upgrade found"), which then read as a hard failure.
refresh_windows_path() {
  [ -z "${LOCALAPPDATA:-}" ] && return
  local links_dir="${LOCALAPPDATA}/Microsoft/WinGet/Links"
  [ ! -d "$links_dir" ] && return
  case ":$PATH:" in
    *":$links_dir:"*) ;;
    *) PATH="$PATH:$links_dir" ;;
  esac
  hash -r 2>/dev/null || true
}

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux) echo "linux" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *) echo "unknown" ;;
  esac
}

detect_linux_pkg_manager() {
  if command -v apt-get &>/dev/null; then echo "apt"
  elif command -v dnf &>/dev/null; then echo "dnf"
  elif command -v pacman &>/dev/null; then echo "pacman"
  elif command -v zypper &>/dev/null; then echo "zypper"
  else echo "unknown"
  fi
}

detect_windows_pkg_manager() {
  if command -v winget &>/dev/null; then echo "winget"
  elif command -v choco &>/dev/null; then echo "choco"
  elif command -v scoop &>/dev/null; then echo "scoop"
  else echo "unknown"
  fi
}

# Args: dep_name brew_pkg apt_pkg dnf_pkg pacman_pkg zypper_pkg winget_id choco_pkg scoop_pkg
# Returns 0 if installed successfully, 1 if unavailable/declined/failed
# (caller should fall back to manual instructions on non-zero).
auto_install_dep() {
  local dep_name="$1" brew_pkg="$2" apt_pkg="$3" dnf_pkg="$4" pacman_pkg="$5" zypper_pkg="$6" winget_id="$7" choco_pkg="$8" scoop_pkg="$9"

  # No real terminal to prompt on (CI, piped install) — skip, let caller show manual steps.
  if [ ! -t 0 ] && [ ! -r /dev/tty ]; then
    return 1
  fi

  local os install_cmd=""
  os=$(detect_os)

  case "$os" in
    macos)
      command -v brew &>/dev/null && install_cmd="brew install ${brew_pkg}"
      ;;
    linux)
      local sudo_prefix=""
      [ "$(id -u)" -ne 0 ] && command -v sudo &>/dev/null && sudo_prefix="sudo "
      case "$(detect_linux_pkg_manager)" in
        apt)    install_cmd="${sudo_prefix}apt-get install -y ${apt_pkg}" ;;
        dnf)    install_cmd="${sudo_prefix}dnf install -y ${dnf_pkg}" ;;
        pacman) install_cmd="${sudo_prefix}pacman -S --noconfirm ${pacman_pkg}" ;;
        zypper) install_cmd="${sudo_prefix}zypper install -y ${zypper_pkg}" ;;
      esac
      ;;
    windows)
      case "$(detect_windows_pkg_manager)" in
        winget) install_cmd="winget install -e --id ${winget_id}" ;;
        choco)  install_cmd="choco install -y ${choco_pkg}" ;;
        scoop)  install_cmd="scoop install ${scoop_pkg}" ;;
      esac
      ;;
  esac

  [ -z "$install_cmd" ] && return 1

  echo ""
  echo "Phát hiện có thể tự động cài ${dep_name} bằng lệnh:"
  echo "  ${install_cmd}"
  local reply=""
  read -r -p "Cài ngay? (y/N): " reply < /dev/tty || return 1
  case "$reply" in
    y|Y|yes|Yes) ;;
    *) return 1 ;;
  esac

  echo "Đang cài ${dep_name}..."
  local install_ok=0
  eval "$install_cmd" || install_ok=1

  # Re-scan even on a reported failure: winget exits nonzero for "already
  # installed, no upgrade found" although the binary is genuinely present —
  # the shim just isn't on this session's PATH yet (see refresh_windows_path).
  [ "$os" = "windows" ] && refresh_windows_path

  if [ "$install_ok" -eq 0 ]; then
    echo "  Cài ${dep_name} thành công."
    return 0
  fi
  echo "  Cài ${dep_name} thất bại."
  return 1
}

